				ZIndex = 52,
				Parent = svFrame
			})
			addCorner(satOverlay, 6)

			local satGrad = Instance.new("UIGradient")
			satGrad.Color = ColorSequence.new(Color3.new(1, 1, 1), Color3.new(1, 1, 1))
			satGrad.Transparency = NumberSequence.new({
				NumberSequenceKeypoint.new(0, 0),
				NumberSequenceKeypoint.new(1, 1)
			})
			satGrad.Parent = satOverlay

			local valOverlay = make("Frame", {
				BackgroundColor3 = Color3.new(0, 0, 0),
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 1, 0),
				ZIndex = 53,
				Parent = svFrame
			})
			addCorner(valOverlay, 6)

			local valGrad = Instance.new("UIGradient")
			valGrad.Color = ColorSequence.new(Color3.new(0, 0, 0), Color3.new(0, 0, 0))
			valGrad.Rotation = 90
			valGrad.Transparency = NumberSequence.new({
				NumberSequenceKeypoint.new(0, 1),
				NumberSequenceKeypoint.new(1, 0)
			})
			valGrad.Parent = valOverlay

			local svCursor = make("Frame", {
				BackgroundTransparency = 1,
				AnchorPoint = Vector2.new(0.5, 0.5),
				Size = UDim2.new(0, 10, 0, 10),
				Position = UDim2.new(0.5, 0, 0.5, 0),
				ZIndex = 54,
				Parent = svFrame
			})

			local svCursorStroke = make("UIStroke", {
				Color = Color3.fromRGB(255, 255, 255),
				Thickness = 1.5,
				Parent = svCursor
			})
			addCorner(svCursor, 100)

			local hueBar = make("Frame", {
				BackgroundColor3 = Color3.new(1, 1, 1),
				BorderSizePixel = 0,
				Position = UDim2.new(0, 178, 0, 34),
				Size = UDim2.new(0, 14, 0, 160),
				ZIndex = 51,
				Parent = popup
			})
			addCorner(hueBar, 6)

			local hueGradient = Instance.new("UIGradient")
			hueGradient.Rotation = 90
			hueGradient.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 0, 0)),
				ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 0, 255)),
				ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 0, 255)),
				ColorSequenceKeypoint.new(0.50, Color3.fromRGB(0, 255, 255)),
				ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 255, 0)),
				ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 255, 0)),
				ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 0, 0)),
			})
			hueGradient.Parent = hueBar

			local hueCursor = make("Frame", {
				BackgroundColor3 = Color3.fromRGB(255, 255, 255),
				BorderSizePixel = 0,
				AnchorPoint = Vector2.new(0.5, 0.5),
				Position = UDim2.new(0.5, 0, 0, 0),
				Size = UDim2.new(1, 6, 0, 2),
				ZIndex = 54,
				Parent = hueBar
			})
			addCorner(hueCursor, 100)

			local alphaLabel
			local alphaBack
			local alphaOverlay
			local alphaCursor
			local alphaFade

			if transparencyEnabled then
				alphaLabel = make("TextLabel", {
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 10, 0, 198),
					Size = UDim2.new(1, -20, 0, 16),
					Text = "Transparency",
					TextXAlignment = Enum.TextXAlignment.Left,
					Font = Enum.Font.Gotham,
					TextSize = 11,
					TextColor3 = ui.theme.SubText,
					ZIndex = 51,
					Parent = popup
				})

				alphaBack = makeChecker(popup, 182, 12, 6, 51)
				alphaBack.Position = UDim2.new(0, 10, 0, 216)
				alphaBack.ZIndex = 51

				alphaOverlay = make("Frame", {
					BackgroundColor3 = cpOptions.default or Color3.fromRGB(255, 0, 0),
					BorderSizePixel = 0,
					Size = UDim2.new(1, 0, 1, 0),
					ZIndex = 52,
					Parent = alphaBack
				})
				addCorner(alphaOverlay, 4)

				alphaFade = Instance.new("UIGradient")
				alphaFade.Color = ColorSequence.new(Color3.new(1, 1, 1), Color3.new(1, 1, 1))
				alphaFade.Rotation = 0
				alphaFade.Transparency = NumberSequence.new({
					NumberSequenceKeypoint.new(0, 0),
					NumberSequenceKeypoint.new(1, 1)
				})
				alphaFade.Parent = alphaOverlay

				alphaCursor = make("Frame", {
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					BorderSizePixel = 0,
					AnchorPoint = Vector2.new(0.5, 0.5),
					Position = UDim2.new(0, 0, 0.5, 0),
					Size = UDim2.new(0, 2, 1, 4),
					ZIndex = 54,
					Parent = alphaBack
				})
				addCorner(alphaCursor, 100)
			end

			local infoLabel = make("TextLabel", {
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 10, 1, -18),
				Size = UDim2.new(1, -20, 0, 12),
				Text = "",
				TextXAlignment = Enum.TextXAlignment.Left,
				Font = Enum.Font.Gotham,
				TextSize = 11,
				TextColor3 = ui.theme.SubText,
				ZIndex = 51,
				Parent = popup
			})

			ui:registerTheme(popup, "BackgroundColor3", "LightContrast")
			ui:registerTheme(popupStroke, "Color", "Background")
			ui:registerTheme(popupTitle, "TextColor3", "TextColor")
			ui:registerTheme(infoLabel, "TextColor3", "SubText")
			if alphaLabel then
				ui:registerTheme(alphaLabel, "TextColor3", "SubText")
			end

			local api = {}
			api.Value = cpOptions.default or Color3.fromRGB(255, 0, 0)
			api.Transparency = transparencyEnabled and math.clamp(tonumber(cpOptions.transparency) or 0, 0, 1) or nil

			local h, s, v = Color3.toHSV(api.Value)
			local svDragging = false
			local hueDragging = false
			local alphaDragging = false
			local popupOpen = false

			local function fireCallback()
				if transparencyEnabled then
					safeCall(cpOptions.callback, api.Value, api.Transparency)
				else
					safeCall(cpOptions.callback, api.Value)
				end
			end

			local function refresh(noCallback)
				api.Value = Color3.fromHSV(h, s, v)

				svFrame.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
				svCursor.Position = UDim2.new(s, 0, 1 - v, 0)
				hueCursor.Position = UDim2.new(0.5, 0, 1 - h, 0)

				previewFill.BackgroundColor3 = api.Value
				previewText.Text = transparencyEnabled
					and (("#%s  %d%%"):format(colorToHex(api.Value), math.floor((1 - api.Transparency) * 100 + 0.5)))
					or ("#%s"):format(colorToHex(api.Value))

				infoLabel.Text = ("RGB %d, %d, %d  |  #%s"):format(
					math.floor(api.Value.R * 255 + 0.5),
					math.floor(api.Value.G * 255 + 0.5),
					math.floor(api.Value.B * 255 + 0.5),
					colorToHex(api.Value)
				)

				if transparencyEnabled and alphaOverlay and alphaCursor then
					alphaOverlay.BackgroundColor3 = api.Value
					alphaCursor.Position = UDim2.new(api.Transparency, 0, 0.5, 0)
				end

				if not noCallback then
					fireCallback()
				end
			end

			local function positionPopup()
				local rel = shell.AbsolutePosition - ui.main.AbsolutePosition
				local x = ui.main.AbsoluteSize.X - popup.AbsoluteSize.X - 12
				x = math.max(x, 210)

				local y = rel.Y + shell.AbsoluteSize.Y + 6
				if y + popup.Size.Y.Offset > ui.main.AbsoluteSize.Y - 10 then
					y = rel.Y - popup.Size.Y.Offset - 6
				end
				if y < 52 then
					y = 52
				end

				popup.Position = UDim2.new(0, x, 0, y)
			end

			local function closePopup()
				if not popupOpen then
					return
				end

				popupOpen = false
				tween(popupScale, {Scale = 0.96}, 0.12)
				task.delay(0.12, function()
					if popup and not popupOpen and not ui._destroyed then
						popup.Visible = false
						popupScale.Scale = 1
					end
				end)

				if ui._activePopupCloser == closePopup then
					ui._activePopupCloser = nil
				end
			end

			local function openPopup()
				if ui._activePopupCloser and ui._activePopupCloser ~= closePopup then
					pcall(ui._activePopupCloser)
				end

				ui._activePopupCloser = closePopup
				positionPopup()
				popup.Visible = true
				popupOpen = true
				popupScale.Scale = 0.96
				tween(popupScale, {Scale = 1}, 0.15)
			end

			local function updateSV(inputPos)
				local rel = inputPos - svFrame.AbsolutePosition
				s = math.clamp(rel.X / math.max(svFrame.AbsoluteSize.X, 1), 0, 1)
				v = 1 - math.clamp(rel.Y / math.max(svFrame.AbsoluteSize.Y, 1), 0, 1)
				refresh()
			end

			local function updateHue(inputPos)
				local rel = inputPos - hueBar.AbsolutePosition
				h = 1 - math.clamp(rel.Y / math.max(hueBar.AbsoluteSize.Y, 1), 0, 1)
				refresh()
			end

			local function updateAlpha(inputPos)
				if not transparencyEnabled or not alphaBack then
					return
				end
				local rel = inputPos - alphaBack.AbsolutePosition
				api.Transparency = math.clamp(rel.X / math.max(alphaBack.AbsoluteSize.X, 1), 0, 1)
				refresh()
			end

			function api:SetValue(color, transparency, noCallback)
				if typeof(color) == "Color3" then
					h, s, v = Color3.toHSV(color)
					api.Value = color
				end

				if transparencyEnabled and transparency ~= nil then
					api.Transparency = math.clamp(tonumber(transparency) or 0, 0, 1)
				end

				refresh(noCallback)
			end

			function api:SetTransparency(value, noCallback)
				if transparencyEnabled then
					api.Transparency = math.clamp(tonumber(value) or 0, 0, 1)
					refresh(noCallback)
				end
			end

			function api:Open()
				openPopup()
			end

			function api:Close()
				closePopup()
			end

			ui:_connect(previewButton.MouseButton1Click, function()
				if popupOpen then
					closePopup()
				else
					openPopup()
				end
			end)

			ui:_connect(svFrame.InputBegan, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					svDragging = true
					updateSV(input.Position)
				end
			end)

			ui:_connect(hueBar.InputBegan, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					hueDragging = true
					updateHue(input.Position)
				end
			end)

			if transparencyEnabled and alphaBack then
				ui:_connect(alphaBack.InputBegan, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						alphaDragging = true
						updateAlpha(input.Position)
					end
				end)
			end

			ui:_connect(UserInputService.InputChanged, function(input)
				if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then
					return
				end

				if svDragging then
					updateSV(input.Position)
				elseif hueDragging then
					updateHue(input.Position)
				elseif alphaDragging then
					updateAlpha(input.Position)
				end
			end)

			ui:_connect(UserInputService.InputEnded, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					svDragging = false
					hueDragging = false
					alphaDragging = false
				end
			end)

			ui:_connect(UserInputService.InputBegan, function(input, gpe)
				if gpe or not popupOpen then
					return
				end

				if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then
					return
				end

				local pos = input.Position

				local function inBounds(guiObject)
					local ap = guiObject.AbsolutePosition
					local as = guiObject.AbsoluteSize
					return pos.X >= ap.X and pos.Y >= ap.Y and pos.X <= ap.X + as.X and pos.Y <= ap.Y + as.Y
				end

				if not inBounds(popup) and not inBounds(previewButton) then
					closePopup()
				end
			end)

			ui:_addRefresh(function()
				refresh(true)
			end)

			refresh(true)
			ui:_registerControl(section, cpOptions.title or "Color Picker", shell, "colorpicker", cpOptions.keywords)

			return api
		end

		ui:RefreshSearch(ui.searchQuery)
		return section
	end

	self:RefreshSearch(self.searchQuery)
	return page
