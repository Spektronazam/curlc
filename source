						Size = UDim2.new(1, -12, 1, 0),
						Position = UDim2.new(0, 6, 0, 0),
						Text = buttonDisplay(value),
						TextXAlignment = Enum.TextXAlignment.Left,
						Font = Enum.Font.Gotham,
						TextSize = 12,
						TextColor3 = ui.theme.SubText,
						Parent = optionButton
					})

					ui:_connect(optionButton.MouseEnter, function()
						if api.Value ~= value then
							tween(optionButton, {BackgroundColor3 = ui.theme.LightContrast}, 0.12)
						end
					end)

					ui:_connect(optionButton.MouseLeave, function()
						if api.Value ~= value then
							tween(optionButton, {BackgroundColor3 = ui.theme.Background}, 0.12)
						end
					end)

					ui:_connect(optionButton.MouseButton1Click, function()
						api:SetValue(value)
						setOpen(false)
					end)

					table.insert(buttons, {
						button = optionButton,
						label = optionLabel,
						value = value
					})
				end

				refreshButtons()
			end

			function api:SetList(newList)
				values = {}
				for _, item in ipairs(newList or {}) do
					table.insert(values, item)
				end
				rebuild()

				if #values > 0 and api.Value == nil then
					api:SetValue(values[1], true)
				elseif #values == 0 then
					api.Value = nil
					valueLabel.Text = "-"
				end
			end

			function api:SetValue(value, noCallback)
				if typeof(value) == "number" and values[value] ~= nil then
					value = values[value]
				end

				if value ~= nil and table.find(values, value) == nil then
					return
				end

				api.Value = value
				valueLabel.Text = value and buttonDisplay(value) or "-"
				refreshButtons()

				if not noCallback then
					safeCall(dropOptions.callback, api.Value)
				end
			end

			ui:_connect(header.MouseButton1Click, function()
				setOpen(not open)
			end)

			ui:_connect(listLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
				if open then
					setOpen(true)
				end
			end)

			ui:_addRefresh(function()
				rebuild()
				refreshButtons()
			end)

			rebuild()

			if #values > 0 then
				api:SetValue(dropOptions.default or values[1], true)
			else
				valueLabel.Text = "-"
			end

			ui:_registerControl(section, dropOptions.title or "Dropdown", shell, "dropdown", dropOptions.keywords)
			return api
		end

		function section:addColorPicker(cpOptions)
