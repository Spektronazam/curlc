            rowLbl.TextSize          = 12
            rowLbl.TextColor3        = self.theme.TextColor
            rowLbl.Parent            = row
            self:_bindTheme(rowLbl, "TextColor3", "TextColor")

            -- Swatch
            local swatchOuter = Instance.new("Frame")
            swatchOuter.Size             = UDim2.new(0, 22, 0, 18)
            swatchOuter.Position         = UDim2.new(1, -32, 0.5, -9)
            swatchOuter.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            swatchOuter.BorderSizePixel  = 0
            swatchOuter.Parent           = row
            newCorner(5, swatchOuter)

            local swatch = Instance.new("Frame")
            swatch.Size             = UDim2.new(1, -2, 1, -2)
            swatch.Position         = UDim2.new(0, 1, 0, 1)
            swatch.BackgroundColor3 = defaultColor
            swatch.BorderSizePixel  = 0
            swatch.Parent           = swatchOuter
            newCorner(4, swatch)

            -- Popup
            local POPUP_W = 236
            local POPUP_H = useAlpha and 268 or 248

            local popup = Instance.new("Frame")
            popup.Size             = UDim2.new(0, POPUP_W, 0, POPUP_H)
            popup.Position         = UDim2.new(0, 0, 1, 6)
            popup.BackgroundColor3 = self.theme.DarkContrast
            popup.BorderSizePixel  = 0
            popup.Visible          = false
            popup.ZIndex           = 50
            popup.ClipsDescendants = false
            popup.Parent           = row
            newCorner(8, popup)
            newPadding(10, 10, 10, 10, popup)

            local popupStroke = Instance.new("UIStroke")
            popupStroke.Color       = Color3.fromRGB(50, 50, 66)
            popupStroke.Thickness   = 1
            popupStroke.Parent      = popup

            self:_bindTheme(popup, "BackgroundColor3", "DarkContrast")

            -- Popup shadow
            local popShadow = Instance.new("ImageLabel")
            popShadow.Size              = UDim2.new(1, 30, 1, 30)
            popShadow.Position          = UDim2.new(0, -15, 0, -15)
            popShadow.BackgroundTransparency = 1
            popShadow.Image             = "rbxassetid://6014261993"
            popShadow.ImageColor3       = Color3.fromRGB(0,0,0)
            popShadow.ImageTransparency = 0.6
            popShadow.ScaleType         = Enum.ScaleType.Slice
            popShadow.SliceCenter       = Rect.new(49,49,450,450)
            popShadow.ZIndex            = 49
            popShadow.Parent            = popup

            local SV_SIZE = POPUP_W - 20  -- 216px

            -- ── SV Square ──
            local svFrame = Instance.new("Frame")
            svFrame.Size             = UDim2.new(0, SV_SIZE, 0, SV_SIZE - 30)
            svFrame.BackgroundColor3 = Color3.fromHSV(H, 1, 1)
            svFrame.BorderSizePixel  = 0
            svFrame.ZIndex           = 51
            svFrame.Parent           = popup
            newCorner(5, svFrame)

            -- White overlay (left → right  white → transparent)
            local svWhite = Instance.new("ImageLabel")
            svWhite.Size                  = UDim2.new(1, 0, 1, 0)
            svWhite.BackgroundTransparency = 1
            svWhite.Image                 = "rbxassetid://4155801252"
            svWhite.ZIndex                = 52
            svWhite.Parent                = svFrame

            -- Black overlay (bottom → top  black → transparent)
            local svBlack = Instance.new("ImageLabel")
            svBlack.Size                  = UDim2.new(1, 0, 1, 0)
            svBlack.BackgroundTransparency = 1
            svBlack.Image                 = "rbxassetid://4155801252"
            svBlack.ImageColor3           = Color3.fromRGB(0,0,0)
            svBlack.Rotation              = 90
            svBlack.ZIndex                = 53
            svBlack.Parent                = svFrame

            -- SV knob
            local svKnob = Instance.new("Frame")
            svKnob.Size             = UDim2.new(0, 12, 0, 12)
            svKnob.BackgroundColor3 = Color3.fromRGB(255,255,255)
            svKnob.BorderSizePixel  = 0
            svKnob.ZIndex           = 55
            svKnob.Parent           = svFrame
            newCorner(99, svKnob)

            local svKnobInner = Instance.new("Frame")
            svKnobInner.Size              = UDim2.new(0, 6, 0, 6)
            svKnobInner.Position          = UDim2.new(0, 3, 0, 3)
            svKnobInner.BackgroundColor3  = Color3.fromRGB(0,0,0)
            svKnobInner.BackgroundTransparency = 0.6
            svKnobInner.BorderSizePixel   = 0
            svKnobInner.ZIndex            = 56
            svKnobInner.Parent            = svKnob
            newCorner(99, svKnobInner)

            -- SV click
            local svClick = Instance.new("TextButton")
            svClick.Size                  = UDim2.new(1, 0, 1, 0)
            svClick.BackgroundTransparency = 1
            svClick.Text                  = ""
            svClick.ZIndex                = 57
            svClick.Parent                = svFrame

            -- ── Hue bar ──
            local HUE_Y = (SV_SIZE - 30) + 8

            local hueBar = Instance.new("Frame")
            hueBar.Size             = UDim2.new(0, SV_SIZE, 0, 12)
            hueBar.Position         = UDim2.new(0, 0, 0, HUE_Y)
            hueBar.BackgroundColor3 = Color3.fromRGB(255,255,255)
            hueBar.BorderSizePixel  = 0
            hueBar.ZIndex           = 51
            hueBar.Parent           = popup
            newCorner(99, hueBar)

            -- Hue gradient via UIGradient
            local hueGrad = Instance.new("UIGradient")
            hueGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0,    Color3.fromHSV(0,   1, 1)),
                ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167,1,1)),
                ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333,1,1)),
                ColorSequenceKeypoint.new(0.5,  Color3.fromHSV(0.5, 1,1)),
                ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667,1,1)),
                ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833,1,1)),
                ColorSequenceKeypoint.new(1,    Color3.fromHSV(1,   1,1)),
            })
            hueGrad.Parent = hueBar

            local hueKnob = Instance.new("Frame")
            hueKnob.Size             = UDim2.new(0, 10, 1, 4)
            hueKnob.BackgroundColor3 = Color3.fromRGB(255,255,255)
            hueKnob.BorderSizePixel  = 0
            hueKnob.ZIndex           = 52
            hueKnob.Position         = UDim2.new(H, -5, 0, -2)
            hueKnob.Parent           = hueBar
            newCorner(99, hueKnob)

            local hueClick = Instance.new("TextButton")
            hueClick.Size                  = UDim2.new(1, 0, 1, 8)
            hueClick.Position              = UDim2.new(0, 0, 0, -4)
            hueClick.BackgroundTransparency = 1
            hueClick.Text                  = ""
            hueClick.ZIndex                = 53
            hueClick.Parent                = hueBar

            -- ── Alpha bar (optional) ──
            local alphaBar, alphaKnob, alphaClick
            local ALPHA_Y = HUE_Y + 20

            if useAlpha then
                alphaBar = Instance.new("Frame")
                alphaBar.Size             = UDim2.new(0, SV_SIZE, 0, 12)
                alphaBar.Position         = UDim2.new(0, 0, 0, ALPHA_Y)
                alphaBar.BorderSizePixel  = 0
                alphaBar.ZIndex           = 51
                alphaBar.Parent           = popup
                newCorner(99, alphaBar)

                -- Checkerboard BG image for transparency preview
                local alphaBG = Instance.new("ImageLabel")
                alphaBG.Size               = UDim2.new(1,0,1,0)
                alphaBG.BackgroundTransparency = 1
                alphaBG.Image              = "rbxassetid://9968344227"
                alphaBG.ScaleType          = Enum.ScaleType.Tile
                alphaBG.TileSize           = UDim2.new(0,12,0,12)
                alphaBG.ZIndex             = 51
                alphaBG.Parent             = alphaBar
                newCorner(99, alphaBG)

                local alphaGradFrame = Instance.new("Frame")
                alphaGradFrame.Size = UDim2.new(1,0,1,0)
                alphaGradFrame.BackgroundColor3 = defaultColor
                alphaGradFrame.BorderSizePixel = 0
                alphaGradFrame.ZIndex = 52
                alphaGradFrame.Parent = alphaBar
                newCorner(99, alphaGradFrame)

                local alphaGrad = Instance.new("UIGradient")
                alphaGrad.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 1),
                    NumberSequenceKeypoint.new(1, 0),
                })
                alphaGrad.Parent = alphaGradFrame

                alphaKnob = Instance.new("Frame")
                alphaKnob.Size             = UDim2.new(0, 10, 1, 4)
                alphaKnob.BackgroundColor3 = Color3.fromRGB(255,255,255)
                alphaKnob.BorderSizePixel  = 0
                alphaKnob.ZIndex           = 54
                alphaKnob.Position         = UDim2.new(1 - Alpha, -5, 0, -2)
                alphaKnob.Parent           = alphaBar
                newCorner(99, alphaKnob)

                alphaClick = Instance.new("TextButton")
                alphaClick.Size                  = UDim2.new(1, 0, 1, 8)
                alphaClick.Position              = UDim2.new(0, 0, 0, -4)
                alphaClick.BackgroundTransparency = 1
                alphaClick.Text                  = ""
                alphaClick.ZIndex                = 55
                alphaClick.Parent                = alphaBar
            end

            -- ── RGB + Hex inputs ──
            local BOT_Y = useAlpha and (ALPHA_Y + 20) or (HUE_Y + 20)

            local function makeInput(placeholder, xPos, w, parent)
                local f = Instance.new("Frame")
                f.Size             = UDim2.new(0, w, 0, 22)
                f.Position         = UDim2.new(0, xPos, 0, BOT_Y)
                f.BackgroundColor3 = self.theme.ElementBG
                f.BorderSizePixel  = 0
                f.ZIndex           = 51
                f.Parent           = parent or popup
                newCorner(4, f)
                self:_bindTheme(f, "BackgroundColor3", "ElementBG")

                local box = Instance.new("TextBox")
                box.Size              = UDim2.new(1, -6, 1, 0)
                box.Position          = UDim2.new(0, 3, 0, 0)
                box.BackgroundTransparency = 1
                box.PlaceholderText   = placeholder
                box.PlaceholderColor3 = self.theme.SubText
                box.Text              = ""
                box.Font              = Enum.Font.GothamMedium
                box.TextSize          = 11
                box.TextColor3        = self.theme.TextColor
                box.ZIndex            = 52
                box.Parent            = f
                self:_bindTheme(box, "TextColor3", "TextColor")
                self:_bindTheme(box, "PlaceholderColor3", "SubText")

                return box, f
            end

            local gap = 4
            local inputW = math.floor((SV_SIZE - gap * 3) / 4)

            local rBox = makeInput("R", 0,                        inputW)
            local gBox = makeInput("G", inputW + gap,             inputW)
            local bBox = makeInput("B", (inputW + gap) * 2,      inputW)
            local hexBox = makeInput("#hex", (inputW + gap) * 3, inputW)

            -- ── Copy RGB button ──
            local copyBtn = Instance.new("TextButton")
            copyBtn.Size              = UDim2.new(0, SV_SIZE, 0, 22)
            copyBtn.Position          = UDim2.new(0, 0, 0, BOT_Y + 26)
            copyBtn.BackgroundColor3  = self.theme.ElementBG
            copyBtn.BorderSizePixel   = 0
            copyBtn.Font              = Enum.Font.GothamMedium
            copyBtn.TextSize          = 11
            copyBtn.TextColor3        = self.theme.SubText
            copyBtn.Text              = "Copy RGB to clipboard"
            copyBtn.AutoButtonColor   = false
            copyBtn.ZIndex            = 51
            copyBtn.Parent            = popup
            newCorner(4, copyBtn)
            self:_bindTheme(copyBtn, "BackgroundColor3", "ElementBG")
            self:_bindTheme(copyBtn, "TextColor3", "SubText")

            self:_connect(copyBtn.MouseButton1Click, function()
                local r = math.floor(currentColor.R * 255)
                local g = math.floor(currentColor.G * 255)
                local b = math.floor(currentColor.B * 255)
                pcall(setclipboard, r .. ", " .. g .. ", " .. b)
                copyBtn.Text = "Copied!"
                task.delay(1.5, function() copyBtn.Text = "Copy RGB to clipboard" end)
            end)

            -- ── Update functions ──
            local function updateAll()
                currentColor = Color3.fromHSV(H, S, V)
                swatch.BackgroundColor3 = currentColor
                svFrame.BackgroundColor3 = Color3.fromHSV(H, 1, 1)

                -- SV knob position
                svKnob.Position = UDim2.new(S, -6, 1 - V, -6)

                -- Hue knob
                hueKnob.Position = UDim2.new(H, -5, 0, -2)

                -- Alpha knob
                if alphaKnob then
                    alphaKnob.Position = UDim2.new(1 - Alpha, -5, 0, -2)
                end

                -- Inputs
                rBox.Text   = tostring(math.floor(currentColor.R * 255))
                gBox.Text   = tostring(math.floor(currentColor.G * 255))
                bBox.Text   = tostring(math.floor(currentColor.B * 255))
                hexBox.Text = string.format("%02X%02X%02X",
                    math.floor(currentColor.R * 255),
                    math.floor(currentColor.G * 255),
                    math.floor(currentColor.B * 255)
                )

                safeCall(opts.callback or function() end, currentColor, 1 - Alpha)
            end

            updateAll()

            -- SV drag
            local svDragging = false
            local function updateSV(pos)
                local abs = svFrame.AbsolutePosition
                local sz  = svFrame.AbsoluteSize
                S = math.clamp((pos.X - abs.X) / sz.X, 0, 1)
                V = math.clamp(1 - (pos.Y - abs.Y) / sz.Y, 0, 1)
                updateAll()
            end

            self:_connect(svClick.MouseButton1Down, function() svDragging = true end)
            self:_connect(UserInputService.InputEnded, function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then svDragging = false end
            end)
            self:_connect(UserInputService.InputChanged, function(inp)
                if svDragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSV(inp.Position)
                end
            end)
            self:_connect(svClick.MouseButton1Click, function()
                updateSV(UserInputService:GetMouseLocation())
            end)

            -- Hue drag
            local hueDragging = false
            local function updateHue(pos)
                local abs = hueBar.AbsolutePosition
                local sz  = hueBar.AbsoluteSize
                H = math.clamp((pos.X - abs.X) / sz.X, 0, 1)
                updateAll()
            end

            self:_connect(hueClick.MouseButton1Down, function() hueDragging = true end)
            self:_connect(UserInputService.InputEnded, function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then hueDragging = false end
            end)
            self:_connect(UserInputService.InputChanged, function(inp)
                if hueDragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                    updateHue(inp.Position)
                end
            end)
            self:_connect(hueClick.MouseButton1Click, function()
                updateHue(UserInputService:GetMouseLocation())
            end)

            -- Alpha drag
            if alphaClick then
                local alphaDragging = false
                local function updateAlpha(pos)
                    local abs = alphaBar.AbsolutePosition
                    local sz  = alphaBar.AbsoluteSize
                    Alpha = 1 - math.clamp((pos.X - abs.X) / sz.X, 0, 1)
                    updateAll()
                end

                self:_connect(alphaClick.MouseButton1Down, function() alphaDragging = true end)
                self:_connect(UserInputService.InputEnded, function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then alphaDragging = false end
                end)
                self:_connect(UserInputService.InputChanged, function(inp)
                    if alphaDragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                        updateAlpha(inp.Position)
                    end
                end)
                self:_connect(alphaClick.MouseButton1Click, function()
                    updateAlpha(UserInputService:GetMouseLocation())
                end)
            end

            -- RGB input FocusLost
            local function applyRGBInput()
                local r = tonumber(rBox.Text)
                local g = tonumber(gBox.Text)
                local b = tonumber(bBox.Text)
                if r and g and b then
                    r = math.clamp(r, 0, 255)
                    g = math.clamp(g, 0, 255)
                    b = math.clamp(b, 0, 255)
                    local c = Color3.fromRGB(r, g, b)
                    H, S, V = Color3.toHSV(c)
                    updateAll()
                end
            end

            self:_connect(rBox.FocusLost, applyRGBInput)
            self:_connect(gBox.FocusLost, applyRGBInput)
            self:_connect(bBox.FocusLost, applyRGBInput)

            self:_connect(hexBox.FocusLost, function()
                local hex = hexBox.Text:gsub("#", "")
                if #hex == 6 then
                    local r = tonumber(hex:sub(1,2), 16)
                    local g = tonumber(hex:sub(3,4), 16)
                    local b = tonumber(hex:sub(5,6), 16)
                    if r and g and b then
                        local c = Color3.fromRGB(r, g, b)
                        H, S, V = Color3.toHSV(c)
                        updateAll()
                    end
                end
            end)

            -- Toggle popup
            local popOpen = false

            local swatchClick = Instance.new("TextButton")
            swatchClick.Size                  = UDim2.new(1, 0, 1, 0)
            swatchClick.BackgroundTransparency = 1
            swatchClick.Text                  = ""
            swatchClick.ZIndex                = 10
            swatchClick.Parent                = swatchOuter

            self:_connect(swatchClick.MouseButton1Click, function()
                popOpen = not popOpen
                if popOpen then
                    popup.Visible = true
                    popup.Size    = UDim2.new(0, POPUP_W, 0, 0)
                    tween(popup, { Size = UDim2.new(0, POPUP_W, 0, POPUP_H) }, 0.20)
                else
                    tween(popup, { Size = UDim2.new(0, POPUP_W, 0, 0) }, 0.15)
                    task.delay(0.16, function()
                        popup.Visible = false
                    end)
                end
            end)

            -- Close when clicking outside
            self:_connect(UserInputService.InputBegan, function(inp, gpe)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 and popOpen then
                    local mp = UserInputService:GetMouseLocation()
                    local abs = popup.AbsolutePosition
                    local sz  = popup.AbsoluteSize
                    local swAbs = swatchOuter.AbsolutePosition
                    local swSz  = swatchOuter.AbsoluteSize

                    local overPopup = mp.X >= abs.X and mp.X <= abs.X + sz.X and mp.Y >= abs.Y and mp.Y <= abs.Y + sz.Y
                    local overSwatch = mp.X >= swAbs.X and mp.X <= swAbs.X + swSz.X and mp.Y >= swAbs.Y and mp.Y <= swAbs.Y + swSz.Y

                    if not overPopup and not overSwatch then
                        popOpen = false
                        tween(popup, { Size = UDim2.new(0, POPUP_W, 0, 0) }, 0.15)
                        task.delay(0.16, function()
                            popup.Visible = false
                        end)
                    end
                end
            end)

            hoverRow(row)

            local cpObj = {
                getValue = function() return currentColor end,
                getAlpha = function() return 1 - Alpha end,
                set = function(color, alpha)
                    H, S, V = Color3.toHSV(color)
                    if alpha ~= nil then Alpha = 1 - alpha end
                    updateAll()
                end,
            }

            regCtrl(opts.title or "Color Picker", row, "colorpicker", opts.keywords)
            return cpObj, secAPI
        end

        -------------------------------------
        -- Done / chain
        -------------------------------------
        function secAPI:done()
            return pageAPI
        end

        return secAPI
    end

    function pageAPI:done()
        return curl
    end

    return pageAPI
end

return curl
