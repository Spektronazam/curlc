	self.toastHost = toastHost

	self:Track(commandBtn.MouseButton1Click:Connect(function()
		self:ToggleCommandPalette()
	end))

	local dragging = false
	local dragInput: InputObject? = nil
	local dragStart = Vector2.zero
	local startPos = main.Position

	self:Track(topbar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = main.Position

			self:Track(input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end))
		end
	end))

	self:Track(topbar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end))

	self:Track(UserInputService.InputChanged:Connect(function(input)
		if dragging and dragInput == input then
			local delta = input.Position - dragStart
			main.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end))
end

function curl:_bindGlobals()
	self:Track(UserInputService.InputBegan:Connect(function(input, gpe)
		if gpe then
			return
		end

		if self._captureBindHandle then
			if input.KeyCode ~= Enum.KeyCode.Unknown then
				self._captureBindHandle:Set(input.KeyCode)
			end
			self._captureBindHandle = nil
			return
		end

		if input.KeyCode == self.toggleKey then
			self:toggle()
			return
		end

		local ctrlDown = UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)
		if ctrlDown and input.KeyCode == Enum.KeyCode.K then
			self:ToggleCommandPalette()
			return
		end

		for _, bind in ipairs(self._keybinds) do
			if bind.enabled and bind.key == input.KeyCode then
				safeCall(bind.callback, input.KeyCode)
			end
		end
	end))
end

function curl.new(options: Dict?)
	options = asTable(options)

	local self = setmetatable({}, curl)

	self._maid = Maid.new()
	self._tweens = setmetatable({}, {__mode = "k"})
	self._themeBindings = {}
	self._commands = {}
	self._keybinds = {}
	self._captureBindHandle = nil

	self.theme = deepCopy(DEFAULT_THEME)
	for k, v in pairs(asTable(options.theme)) do
		if self.theme[k] ~= nil then
			self.theme[k] = v
		end
	end

	self.title = asString(options.title, "curl-c v2")
	self.subtitle = asString(options.subtitle, "shadcn-ish ui foundation")
	self.size = typeof(options.size) == "UDim2" and options.size or UDim2.fromOffset(980, 580)
	self.toggleKey = asKeyCode(options.toggleKey, Enum.KeyCode.RightShift)
	self.visible = true
	self.pages = {}
	self.currentPage = nil

	self:_buildWindow(options)
	self:_buildCommandPalette()
	self:_bindGlobals()

	return self
end

function curl:SelectPage(options: Dict)
	options = asTable(options)
	local page = options.page
	if not page then
		return
	end

	if self.currentPage and self.currentPage ~= page then
		self.currentPage.pageFrame.Visible = false
		self:Tween(self.currentPage.tabButton, {
			BackgroundTransparency = 1,
		}, 0.12)
	end

	self.currentPage = page
	page.pageFrame.Visible = true
	self:Tween(page.tabButton, {
		BackgroundTransparency = 0.15,
	}, 0.12)

	if options.toggle ~= nil then
		self:SetVisible(asBoolean(options.toggle, true))
	end
end

