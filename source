	}, sv)
	corner(blackOverlay, 8)
	create("UIGradient", {
		Rotation = 90,
		Transparency = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 1),
			NumberSequenceKeypoint.new(1, 0),
		}),
	}, blackOverlay)

	local svKnob = create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(10, 10),
		ZIndex = 44,
	}, sv) :: Frame
	corner(svKnob, 999)
	stroke(svKnob, Color3.new(0, 0, 0), 0.4)

	local hueBar = create("TextButton", {
		AutoButtonColor = false,
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(198, 10),
		Size = UDim2.fromOffset(16, 132),
		Text = "",
		ZIndex = 41,
	}, popover) :: TextButton
	corner(hueBar, 999)
	create("UIGradient", {
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 0, 0)),
			ColorSequenceKeypoint.new(0.16, Color3.fromRGB(255, 255, 0)),
			ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
			ColorSequenceKeypoint.new(0.50, Color3.fromRGB(0, 255, 255)),
			ColorSequenceKeypoint.new(0.66, Color3.fromRGB(0, 0, 255)),
			ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
			ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 0, 0)),
		}),
	}, hueBar)

	local hueKnob = create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
		Position = UDim2.new(0.5, 0, 0, 0),
		Size = UDim2.new(1, 4, 0, 4),
		ZIndex = 44,
	}, hueBar) :: Frame
	corner(hueKnob, 999)
	stroke(hueKnob, Color3.new(0, 0, 0), 0.4)

	local hexLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(10, 154),
		Size = UDim2.fromOffset(120, 16),
		Text = colorToHex(color),
		TextXAlignment = Enum.TextXAlignment.Left,
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
		ZIndex = 41,
	}, popover) :: TextLabel
	self.window:Bind(hexLabel, "TextColor3", "popoverForeground")

	local done = createButtonShell(self.window, popover, 90, "Done", "secondary")
	done.Position = UDim2.fromOffset(146, 168)
	done.ZIndex = 41

	local hue, sat, val = color:ToHSV()
	local draggingSV = false
	local draggingHue = false

	local function render(fire: boolean?)
		color = Color3.fromHSV(hue, sat, val)
		swatch.BackgroundColor3 = color
		trigger.Text = "   " .. colorToHex(color)
		hexLabel.Text = colorToHex(color)
		sv.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
		svKnob.Position = UDim2.new(sat, 0, 1 - val, 0)
		hueKnob.Position = UDim2.new(0.5, 0, hue, 0)

		if fire then
			safeCall(callback, color)
		end
	end

	local function updateSV(input: InputObject)
		sat = clamp01((input.Position.X - sv.AbsolutePosition.X) / sv.AbsoluteSize.X)
		val = 1 - clamp01((input.Position.Y - sv.AbsolutePosition.Y) / sv.AbsoluteSize.Y)
		render(true)
	end

	local function updateHue(input: InputObject)
		hue = clamp01((input.Position.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y)
		render(true)
	end

	self.window:Track(sv.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingSV = true
			updateSV(input)
		end
	end))

	self.window:Track(hueBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingHue = true
			updateHue(input)
		end
	end))

	self.window:Track(UserInputService.InputChanged:Connect(function(input)
		if draggingSV and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateSV(input)
		elseif draggingHue and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateHue(input)
		end
	end))

	self.window:Track(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingSV = false
			draggingHue = false
		end
	end))

	self.window:Track(trigger.MouseButton1Click:Connect(function()
		if popover.Visible then
			popover.Visible = false
		else
			self.window:_openPopover(popover, trigger)
		end
	end))

	self.window:Track(done.MouseButton1Click:Connect(function()
		popover.Visible = false
	end))

	render(false)

	local handle = {}
	function handle:Set(nextColor: Color3)
		if typeof(nextColor) == "Color3" then
			color = nextColor
			hue, sat, val = color:ToHSV()
			render(true)
		end
	end
	function handle:Get()
		return color
	end
	function handle:Destroy()
		popover:Destroy()
		right.Parent.Parent:Destroy()
	end
	return handle
end

function Section:addKeybind(options: Dict)
	options = asTable(options)

	local title = asString(options.title, "Keybind")
	local description = asString(options.description, "")
	local callback = asCallback(options.callback)
	local key = asKeyCode(options.default, Enum.KeyCode.Unknown)

	local _, _, right = self:_row(title, description)
	local trigger = createButtonShell(self.window, right, 170, key.Name, "outline")

	local binding = {
		key = key,
		enabled = true,
		callback = callback,
	}

	local function render()
		trigger.Text = binding.key == Enum.KeyCode.Unknown and "Unbound" or binding.key.Name
	end

	local handle = {}
	function handle:Set(nextKey: Enum.KeyCode)
		binding.key = nextKey
		render()
	end
	function handle:Get()
		return binding.key
	end
	function handle:SetEnabled(state: boolean)
		binding.enabled = state
	end
	function handle:Destroy()
		for i, item in ipairs(self.window._keybinds) do
			if item == binding then
				table.remove(self.window._keybinds, i)
				break
			end
		end
		right.Parent.Parent:Destroy()
	end

	render()
	table.insert(self.window._keybinds, binding)

	self.window:Track(trigger.MouseButton1Click:Connect(function()
		trigger.Text = "Press a key..."
		self.window._captureBindHandle = handle
	end))

	return handle
end

function curl:Destroy()
	self._maid:DoCleaning()
	if self.gui then
		self.gui:Destroy()
	end
end

return curl
