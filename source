            dropBtn.Text              = selected
            dropBtn.AutoButtonColor   = false
            dropBtn.ZIndex            = 4
            dropBtn.Parent            = row
            newCorner(5, dropBtn)

            local arrow = Instance.new("TextLabel")
            arrow.Size              = UDim2.new(0, 20, 1, 0)
            arrow.Position          = UDim2.new(1, -22, 0, 0)
            arrow.BackgroundTransparency = 1
            arrow.Text              = "▾"
            arrow.TextSize          = 12
            arrow.Font              = Enum.Font.GothamBold
            arrow.TextColor3        = self.theme.SubText
            arrow.ZIndex            = 5
            arrow.Parent            = dropBtn

            self:_bindTheme(dropBtn, "BackgroundColor3", "DarkContrast")
            self:_bindTheme(dropBtn, "TextColor3", "TextColor")

            -- Dropdown list (renders above everything else)
            local listHolder = Instance.new("Frame")
            listHolder.Size              = UDim2.new(1, 0, 0, 0)
            listHolder.Position          = UDim2.new(0, 0, 1, 4)
            listHolder.BackgroundColor3  = self.theme.LightContrast
            listHolder.BorderSizePixel   = 0
            listHolder.ClipsDescendants  = true
            listHolder.ZIndex            = 20
            listHolder.Visible           = false
            listHolder.Parent            = dropBtn
            newCorner(6, listHolder)

            local listScroll = Instance.new("ScrollingFrame")
            listScroll.Size                  = UDim2.new(1, 0, 1, 0)
            listScroll.BackgroundTransparency = 1
            listScroll.BorderSizePixel       = 0
            listScroll.ScrollBarThickness    = 2
            listScroll.ScrollBarImageColor3  = self.theme.Accent
            listScroll.AutomaticCanvasSize   = Enum.AutomaticSize.Y
            listScroll.CanvasSize            = UDim2.new(0, 0, 0, 0)
            listScroll.ZIndex                = 21
            listScroll.Parent                = listHolder
            newListLayout(listScroll, 2)
            newPadding(4, 4, 4, 4, listScroll)

            self:_bindTheme(listHolder, "BackgroundColor3", "LightContrast")
            self:_bindTheme(listScroll, "ScrollBarImageColor3", "Accent")

            local open = false

            local function buildItems()
                for _, c in ipairs(listScroll:GetChildren()) do
                    if c:IsA("TextButton") then c:Destroy() end
                end
                for _, item in ipairs(items) do
                    local itemBtn = Instance.new("TextButton")
                    itemBtn.Size              = UDim2.new(1, 0, 0, 26)
                    itemBtn.BackgroundColor3  = item == selected and self.theme.ElementBG or Color3.fromRGB(0,0,0)
                    itemBtn.BackgroundTransparency = item == selected and 0 or 1
                    itemBtn.BorderSizePixel   = 0
                    itemBtn.Font              = Enum.Font.Gotham
                    itemBtn.TextSize          = 12
                    itemBtn.TextColor3        = item == selected and self.theme.Accent or self.theme.TextColor
                    itemBtn.Text              = tostring(item)
                    itemBtn.TextXAlignment    = Enum.TextXAlignment.Left
                    itemBtn.AutoButtonColor   = false
                    itemBtn.ZIndex            = 22
                    itemBtn.Parent            = listScroll
                    newCorner(5, itemBtn)
                    newPadding(0, 0, 8, 8, itemBtn)

                    self:_connect(itemBtn.MouseButton1Click, function()
                        selected = item
                        dropBtn.Text = tostring(item)
                        open = false
                        tween(listHolder, { Size = UDim2.new(1, 0, 0, 0) }, 0.16)
                        task.delay(0.17, function() listHolder.Visible = false end)
                        tween(arrow, { Rotation = 0 }, 0.16)
                        buildItems()
                        safeCall(opts.callback or function() end, item)
                    end)
                end
            end

            buildItems()

            local function toggle()
                open = not open
                if open then
                    listHolder.Visible = true
                    local h = math.min(#items * 28 + 8, 130)
                    tween(listHolder, { Size = UDim2.new(1, 0, 0, h) }, 0.18)
                    tween(arrow, { Rotation = 180 }, 0.18)
                else
                    tween(listHolder, { Size = UDim2.new(1, 0, 0, 0) }, 0.14)
                    task.delay(0.15, function() listHolder.Visible = false end)
                    tween(arrow, { Rotation = 0 }, 0.14)
                end
            end

            self:_connect(dropBtn.MouseButton1Click, toggle)
            hoverRow(row)

            local dropObj = {
                value = selected,
                set   = function(v)
                    selected = v
                    dropBtn.Text = tostring(v)
                    buildItems()
                end,
                setItems = function(newItems)
                    items = newItems
                    buildItems()
                end,
            }

            regCtrl(opts.title, row, "dropdown", opts.keywords)
            return dropObj, secAPI
        end

