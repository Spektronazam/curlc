function curl:SelectPage(options)
	options = options or {}
	local page = options.page
	if not page then
		return
	end

	if self._activePopupCloser then
		pcall(self._activePopupCloser)
	end

	if self.currentTab == page then
		if options.toggle ~= nil then
			self:_setOpen(options.toggle)
		end
		return
	end

	local previous = self.currentTab
	self.currentTab = page

	if previous and previous.pageFrame then
		self:_setTabState(previous, false)
		previous.pageFrame.Visible = true
		tween(previous.pageFrame, {Position = UDim2.new(0, -12, 0, 0)}, 0.14)

		task.delay(0.14, function()
			if previous.pageFrame and self.currentTab ~= previous and not self._destroyed then
				previous.pageFrame.Visible = false
				previous.pageFrame.Position = UDim2.new(0, 0, 0, 0)
			end
		end)
	end

	page.pageFrame.Position = UDim2.new(0, 12, 0, 0)
	page.pageFrame.Visible = true
	tween(page.pageFrame, {Position = UDim2.new(0, 0, 0, 0)}, 0.18)
	self:_setTabState(page, true)

	if options.toggle ~= nil then
		self:_setOpen(options.toggle)
	end
end

