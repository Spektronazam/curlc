        function secAPI:addColorPicker(opts)
            opts = opts or {}
            local defaultColor = opts.default or Color3.fromRGB(255, 100, 100)
            local useAlpha     = opts.alpha ~= false

            local H, S, V = Color3.toHSV(defaultColor)
            local Alpha    = opts.defaultAlpha or 1
            local currentColor = defaultColor

            -- Row (swatch + label)
            local row = Instance.new("Frame")
            row.Size             = UDim2.new(1, 0, 0, 32)
            row.BackgroundColor3 = self.theme.ElementBG
            row.BorderSizePixel  = 0
            row.LayoutOrder      = opts._order or 99
            row.ClipsDescendants = false
