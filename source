		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Text = "",
		ZIndex = 60,
	}, self.overlayLayer) :: TextButton

	local shell = create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = self.theme.card,
		BorderSizePixel = 0,
		Position = UDim2.fromScale(0.5, 0.5),
		Size = UDim2.fromOffset(420, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ZIndex = 61,
	}, backdrop) :: Frame

	corner(shell, self.theme.radiusLg)
	local shellStroke = stroke(shell, self.theme.border, 0.88)
	self:Bind(shell, "BackgroundColor3", "card")
	self:Bind(shellStroke, "Color", "border")
	padding(shell, 14, 14, 14, 14)
