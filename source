	local titleLabel = createLabel(self, shell, title, 14, true)
	titleLabel.ZIndex = 62

	if description ~= "" then
		local descLabel = createDescription(self, shell, description)
		descLabel.ZIndex = 62
	end

	createSeparator(self, shell).ZIndex = 62

	local buttonRow = create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 36),
		ZIndex = 62,
	}, shell)

	local rowLayout = listLayout(buttonRow, Enum.FillDirection.Horizontal, 8)
	rowLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right

	local function close()
		backdrop:Destroy()
	end

	if #actions == 0 then
		local ok = createButtonShell(self, buttonRow, 88, "Close", "secondary")
		ok.ZIndex = 62
		self:Track(ok.MouseButton1Click:Connect(close))
	else
		for _, action in ipairs(actions) do
			local btn = createButtonShell(
				self,
				buttonRow,
				asNumber(action.width, 90, 64, 180),
				asString(action.title, "Action"),
				(action.variant or "secondary") :: ButtonVariant
			)
			btn.ZIndex = 62
			self:Track(btn.MouseButton1Click:Connect(function()
				if asBoolean(action.closeOnClick, true) then
					close()
				end
				safeCall(asCallback(action.callback))
			end))
		end
	end

	self:Track(backdrop.MouseButton1Click:Connect(function()
		if asBoolean(options.closeOnBackdrop, true) then
			close()
		end
	end))

	local scale = create("UIScale", {Scale = 0.96}, shell)
	shell.BackgroundTransparency = 1
	self:Tween(shell, {BackgroundTransparency = 0}, 0.16)
	self:Tween(scale, {Scale = 1}, 0.16)

	return {
		Close = close,
		Destroy = close,
	}
end

