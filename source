			ui:registerTheme(titleLabel, "TextColor3", "TextColor")
			ui:registerTheme(valueLabel, "TextColor3", "SubText")
			ui:registerTheme(barBack, "BackgroundColor3", "Background")
			ui:registerTheme(barFill, "BackgroundColor3", "Accent")

			local api = {}
			api.Value = tonumber(slOptions.default)
			if api.Value == nil then
				api.Value = min
			end

			local draggingSlider = false

			local function formatValue(value)
				local text = tostring(value)
				if suffix ~= "" then
					text = text .. tostring(suffix)
				end
				return text
			end

			local function setFromAlpha(alpha, noCallback)
				alpha = math.clamp(alpha, 0, 1)
				local value = min + (max - min) * alpha
				value = round(value, rounding)
				api.Value = value

				local ratio = (api.Value - min) / (max - min == 0 and 1 or (max - min))
				barFill.Size = UDim2.new(ratio, 0, 1, 0)
				knob.Position = UDim2.new(ratio, 0, 0.5, 0)
				valueLabel.Text = formatValue(api.Value)

				if not noCallback then
					safeCall(slOptions.callback, api.Value)
				end
			end

			function api:SetValue(value, noCallback)
				value = math.clamp(tonumber(value) or min, min, max)
				local alpha = (value - min) / (max - min == 0 and 1 or (max - min))
				setFromAlpha(alpha, noCallback)
			end

			local function updateFromInput(posX)
				local abs = barBack.AbsolutePosition.X
				local size = barBack.AbsoluteSize.X
				local alpha = (posX - abs) / math.max(size, 1)
				setFromAlpha(alpha)
			end

			ui:_connect(barBack.InputBegan, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					draggingSlider = true
					updateFromInput(input.Position.X)
				end
			end)

			ui:_connect(UserInputService.InputChanged, function(input)
				if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					updateFromInput(input.Position.X)
				end
			end)

			ui:_connect(UserInputService.InputEnded, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					draggingSlider = false
				end
			end)

			ui:_addRefresh(function()
				barFill.BackgroundColor3 = ui.theme.Accent
				valueLabel.TextColor3 = ui.theme.SubText
				titleLabel.TextColor3 = ui.theme.TextColor
			end)

			api:SetValue(api.Value, true)
			ui:_registerControl(section, slOptions.title or "Slider", shell, "slider", slOptions.keywords)
			return api
		end

