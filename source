        -------------------------------------
        -- Toggle
        -------------------------------------
        function secAPI:addToggle(opts)
            opts = opts or {}
            local row, lbl = makeRow(opts.title or "Toggle", opts._order)

            local state = opts.default or false

            -- Track (pill background)
            local trackW, trackH = 36, 18
            local track = Instance.new("Frame")
            track.Size             = UDim2.new(0, trackW, 0, trackH)
            track.Position         = UDim2.new(1, -(trackW + 10), 0.5, -trackH/2)
            track.BackgroundColor3 = state and self.theme.Accent or Color3.fromRGB(60, 60, 72)
            track.BorderSizePixel  = 0
            track.Parent           = row
            newCorner(99, track)

            -- Knob
            local knobSize = trackH - 4
            local knob = Instance.new("Frame")
            knob.Size             = UDim2.new(0, knobSize, 0, knobSize)
            knob.Position         = UDim2.new(0, state and (trackW - knobSize - 2) or 2, 0.5, -knobSize/2)
            knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            knob.BorderSizePixel  = 0
            knob.Parent           = track
            newCorner(99, knob)

            local click = Instance.new("TextButton")
            click.Size                  = UDim2.new(1, 0, 1, 0)
            click.BackgroundTransparency = 1
            click.Text                  = ""
            click.ZIndex                = 5
            click.Parent                = row

            hoverRow(row)

            local function setState(s, noCallback)
                state = s
                local knobX = s and (trackW - knobSize - 2) or 2
                tween(track, { BackgroundColor3 = s and self.theme.Accent or Color3.fromRGB(60, 60, 72) }, 0.18)
                tween(knob,  { Position = UDim2.new(0, knobX, 0.5, -knobSize/2) }, 0.18)
                if not noCallback then
                    safeCall(opts.callback or function() end, s)
                end
            end

            self:_connect(click.MouseButton1Click, function()
                setState(not state)
            end)

            local togObj = { value = state, set = setState, toggle = function() setState(not state) end }
            regCtrl(opts.title, row, "toggle", opts.keywords)
            return togObj, secAPI
        end

        -------------------------------------
        -- Slider
        -------------------------------------
        function secAPI:addSlider(opts)
            opts = opts or {}
            local min     = opts.min or 0
            local max     = opts.max or 100
            local default = math.clamp(opts.default or min, min, max)
            local suffix  = opts.suffix or ""
            local round   = opts.round or 1

            local row, lbl = makeRow(opts.title or "Slider", opts._order)
            row.Size = UDim2.new(1, 0, 0, 42)

            -- Value label
            local valLbl = Instance.new("TextLabel")
            valLbl.Size              = UDim2.new(0, 60, 0, 16)
            valLbl.Position          = UDim2.new(1, -70, 0, 8)
            valLbl.BackgroundTransparency = 1
            valLbl.TextXAlignment    = Enum.TextXAlignment.Right
            valLbl.Font              = Enum.Font.GothamBold
            valLbl.TextSize          = 11
            valLbl.TextColor3        = self.theme.Accent
            valLbl.Parent            = row
            self:_bindTheme(valLbl, "TextColor3", "Accent")

            -- Track BG
            local trackBG = Instance.new("Frame")
            trackBG.Size             = UDim2.new(1, -20, 0, 5)
            trackBG.Position         = UDim2.new(0, 10, 1, -14)
            trackBG.BackgroundColor3 = Color3.fromRGB(50, 50, 64)
            trackBG.BorderSizePixel  = 0
            trackBG.Parent           = row
            newCorner(99, trackBG)

            -- Track fill
            local trackFill = Instance.new("Frame")
            trackFill.Size             = UDim2.new(0, 0, 1, 0)
            trackFill.BackgroundColor3 = self.theme.Accent
            trackFill.BorderSizePixel  = 0
            trackFill.Parent           = trackBG
            newCorner(99, trackFill)
            self:_bindTheme(trackFill, "BackgroundColor3", "Accent")

            -- Knob
            local sliderKnob = Instance.new("Frame")
            sliderKnob.Size             = UDim2.new(0, 12, 0, 12)
            sliderKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            sliderKnob.BorderSizePixel  = 0
            sliderKnob.ZIndex           = 5
            sliderKnob.Parent           = trackBG
            newCorner(99, sliderKnob)

            local value = default

            local function roundTo(n, r)
                if r <= 0 then return n end
                return math.round(n / r) * r
            end

            local function updateVisual(v, skipTween)
                local pct = (v - min) / (max - min)
                local fillW = pct
                local knobX = pct - 0.04
                if skipTween then
                    trackFill.Size = UDim2.new(fillW, 0, 1, 0)
                    sliderKnob.Position = UDim2.new(math.clamp(knobX, 0, 1), -6, 0.5, -6)
                else
                    tween(trackFill, { Size = UDim2.new(fillW, 0, 1, 0) }, 0.05)
                    sliderKnob.Position = UDim2.new(math.clamp(knobX, 0, 1), -6, 0.5, -6)
                end
                valLbl.Text = tostring(roundTo(v, round)) .. suffix
            end

            updateVisual(default, true)

            local dragging = false
            local click = Instance.new("TextButton")
            click.Size = UDim2.new(1, 0, 1, 12)
            click.Position = UDim2.new(0, 0, 0, -4)
            click.BackgroundTransparency = 1
            click.Text = ""
            click.ZIndex = 6
            click.Parent = trackBG

            local function updateFromMouse(inputPos)
                local abs = trackBG.AbsolutePosition
                local sz  = trackBG.AbsoluteSize
                local pct = math.clamp((inputPos.X - abs.X) / sz.X, 0, 1)
                local raw = min + (max - min) * pct
                value = roundTo(raw, round)
                updateVisual(value)
                safeCall(opts.callback or function() end, value)
            end

            self:_connect(click.MouseButton1Down, function()
                dragging = true
            end)

            self:_connect(UserInputService.InputChanged, function(inp)
                if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
                    updateFromMouse(inp.Position)
                end
            end)

            self:_connect(UserInputService.InputEnded, function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                    if dragging then
                        dragging = false
                        updateFromMouse(inp.Position)
                    end
                end
            end)

            self:_connect(click.MouseButton1Click, function()
                updateFromMouse(UserInputService:GetMouseLocation())
            end)

            hoverRow(row)

            local slObj = {
                value = value,
                set   = function(v)
                    value = math.clamp(roundTo(v, round), min, max)
                    updateVisual(value, true)
                end,
            }

            regCtrl(opts.title, row, "slider", opts.keywords)
            return slObj, secAPI
        end

