	DarkContrast = Color3.fromRGB(14, 14, 14),
	TextColor = Color3.fromRGB(255, 255, 255),
	SubText = Color3.fromRGB(165, 165, 165),
}

local function tween(instance, properties, duration, style, direction)
	local tw = TweenService:Create(
		instance,
		TweenInfo.new(duration or 0.18, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out),
		properties
	)
	tw:Play()
	return tw
end

local function safeCall(func, ...)
	if type(func) ~= "function" then
		return
	end

	local args = table.pack(...)
	task.spawn(function()
		local ok, err = pcall(function()
			func(table.unpack(args, 1, args.n))
		end)
		if not ok then
			warn("[curl-c] callback error:", err)
		end
	end)
end

local function make(className, props)
	local obj = Instance.new(className)
	for k, v in pairs(props or {}) do
		obj[k] = v
	end
	return obj
end

local function round(num, places)
	local mult = 10 ^ (places or 0)
	return math.floor(num * mult + 0.5) / mult
end

local function trim(str)
	return (tostring(str or ""):gsub("^%s+", ""):gsub("%s+$", ""))
end

local function lower(str)
	return string.lower(tostring(str or ""))
end

local function shifted(pos, x, y)
	return UDim2.new(pos.X.Scale, pos.X.Offset + (x or 0), pos.Y.Scale, pos.Y.Offset + (y or 0))
end

local function colorToHex(color)
	return string.format(
		"%02X%02X%02X",
		math.floor(color.R * 255 + 0.5),
		math.floor(color.G * 255 + 0.5),
		math.floor(color.B * 255 + 0.5)
	)
end

local function bindToText(bind)
	if typeof(bind) ~= "EnumItem" then
		return "None"
	end

	if bind.EnumType == Enum.KeyCode then
		return bind.Name
	end

	if bind == Enum.UserInputType.MouseButton1 then
		return "MB1"
	elseif bind == Enum.UserInputType.MouseButton2 then
		return "MB2"
	elseif bind == Enum.UserInputType.MouseButton3 then
		return "MB3"
	end

	return bind.Name
end

local function isMouseBind(bind)
	return typeof(bind) == "EnumItem" and bind.EnumType == Enum.UserInputType
end

local function isKeyBind(bind)
	return typeof(bind) == "EnumItem" and bind.EnumType == Enum.KeyCode
end

local function inputMatchesBind(input, bind)
	if typeof(bind) ~= "EnumItem" then
		return false
	end

	if isKeyBind(bind) then
		return input.KeyCode == bind
	end

	if isMouseBind(bind) then
		return input.UserInputType == bind
	end

	return false
end

local function addCorner(obj, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 8)
	c.Parent = obj
	return c
end

local function makeChecker(parent, width, height, cell, zIndex)
	local holder = make("Frame", {
		BackgroundColor3 = Color3.fromRGB(105, 105, 105),
		BorderSizePixel = 0,
		ClipsDescendants = true,
		Size = UDim2.new(0, width, 0, height),
		ZIndex = zIndex or 1,
		Parent = parent
	})

	addCorner(holder, 4)

	local cols = math.ceil(width / cell)
	local rows = math.ceil(height / cell)

	for y = 0, rows - 1 do
		for x = 0, cols - 1 do
			local square = make("Frame", {
				BackgroundColor3 = ((x + y) % 2 == 0) and Color3.fromRGB(120, 120, 120) or Color3.fromRGB(85, 85, 85),
				BorderSizePixel = 0,
				Size = UDim2.new(0, cell, 0, cell),
				Position = UDim2.new(0, x * cell, 0, y * cell),
				ZIndex = zIndex or 1,
				Parent = holder
			})
		end
	end

	return holder
end

function curl:_connect(signal, fn)
	local connection = signal:Connect(fn)
	table.insert(self._connections, connection)
	return connection
end

function curl:_addRefresh(fn)
	table.insert(self._refreshCallbacks, fn)
	return fn
end

function curl:registerTheme(obj, prop, themeName)
	self.themeObjects[themeName] = self.themeObjects[themeName] or {}
	table.insert(self.themeObjects[themeName], {obj = obj, prop = prop})

	pcall(function()
		obj[prop] = self.theme[themeName]
	end)
end

function curl:updateTheme(themeName, color)
	self.theme[themeName] = color

	for _, item in ipairs(self.themeObjects[themeName] or {}) do
		pcall(function()
			if item.obj then
				item.obj[item.prop] = color
			end
		end)
	end

	for _, page in ipairs(self.pages) do
		self:_setTabState(page, page == self.currentTab, true)
	end

	for _, fn in ipairs(self._refreshCallbacks) do
		pcall(fn)
	end
end

function curl:setTheme(options)
	options = options or {}
	if options.theme and options.color3 then
		self:updateTheme(options.theme, options.color3)
	end
end

function curl:_bindHover(obj, idleTheme, hoverColor)
	if not obj then
		return
	end

	self:_connect(obj.MouseEnter, function()
		if obj:GetAttribute("Selected") then
			return
		end
		tween(obj, {BackgroundColor3 = hoverColor or self.theme.Background}, 0.12)
	end)

	self:_connect(obj.MouseLeave, function()
		if obj:GetAttribute("Selected") then
			return
		end
		tween(obj, {BackgroundColor3 = self.theme[idleTheme]}, 0.12)
	end)
end

function curl:_setOpen(state, instant)
	if self._destroyed then
		return
	end

	if self._activePopupCloser and not state then
		pcall(self._activePopupCloser)
	end

	self._isOpen = state

	if state then
		self.main.Visible = true

		if instant then
			self.main.Position = self._openPosition
			self.mainScale.Scale = 1
			return
		end

		self.main.Position = shifted(self._openPosition, 0, 10)
		self.mainScale.Scale = 0.97

		tween(self.main, {Position = self._openPosition}, 0.18)
		tween(self.mainScale, {Scale = 1}, 0.18)
	else
		if instant then
			self.main.Visible = false
			self.main.Position = self._openPosition
			self.mainScale.Scale = 1
			return
		end

		tween(self.main, {Position = shifted(self._openPosition, 0, 10)}, 0.14)
		tween(self.mainScale, {Scale = 0.97}, 0.14)

		task.delay(0.14, function()
			if self.main and not self._destroyed and not self._isOpen then
				self.main.Visible = false
				self.main.Position = self._openPosition
				self.mainScale.Scale = 1
			end
		end)
	end
end

function curl:toggle()
	self:_setOpen(not self._isOpen)
end

function curl:_setTabState(page, selected, instant)
	if not page or not page.tabButton then
		return
	end

	page.tabButton:SetAttribute("Selected", selected)

	local bg = selected and self.theme.DarkContrast or self.theme.LightContrast
	local text = selected and self.theme.TextColor or self.theme.SubText
	local lineTransparency = selected and 0 or 1

	if instant then
		page.tabButton.BackgroundColor3 = bg
		page.tabTitle.TextColor3 = text
		page.tabIndicator.BackgroundTransparency = lineTransparency
		return
	end

	tween(page.tabButton, {BackgroundColor3 = bg}, 0.16)
	tween(page.tabTitle, {TextColor3 = text}, 0.16)
	tween(page.tabIndicator, {BackgroundTransparency = lineTransparency}, 0.16)
end

function curl:_registerControl(section, title, frame, kind, keywords)
	local packedKeywords = {}

	if type(keywords) == "table" then
		for _, value in ipairs(keywords) do
			table.insert(packedKeywords, tostring(value))
		end
	elseif keywords ~= nil then
		table.insert(packedKeywords, tostring(keywords))
	end

	local meta = {
		title = tostring(title or kind or "Control"),
		frame = frame,
		kind = tostring(kind or "control"),
		keywords = packedKeywords,
		section = section,
		page = section.page
	}

	table.insert(section.controls, meta)
	table.insert(self._controls, meta)

	self:RefreshSearch(self.searchQuery)

	return meta
end

function curl:_matchesSearch(meta, query)
	if query == "" then
		return true
	end

	local haystack = lower(meta.title) .. " " .. lower(meta.kind)

	if meta.section then
		haystack = haystack .. " " .. lower(meta.section.title)
	end

	if meta.page then
		haystack = haystack .. " " .. lower(meta.page.title)
	end

	for _, word in ipairs(meta.keywords or {}) do
		haystack = haystack .. " " .. lower(word)
	end

	return string.find(haystack, query, 1, true) ~= nil
end

function curl:RefreshSearch(query)
	if query ~= nil then
		self.searchQuery = trim(query)
	end

	local search = lower(self.searchQuery or "")
	local firstMatchingPage = nil

	for _, page in ipairs(self.pages) do
		local visibleControlsOnPage = 0

		for _, section in ipairs(page.sections) do
			local sectionMatches = search ~= "" and string.find(lower(section.title), search, 1, true) ~= nil or false
			local visibleControls = 0

			for _, meta in ipairs(section.controls) do
				local visible = (search == "") or sectionMatches or self:_matchesSearch(meta, search)

				if meta.frame then
					meta.frame.Visible = visible
				end

				if visible then
					visibleControls = visibleControls + 1
				end
			end

			local showSection = search == "" or sectionMatches or visibleControls > 0
			section.frame.Visible = showSection

			if showSection then
				visibleControlsOnPage = visibleControlsOnPage + visibleControls
			end
		end

		page._matchCount = visibleControlsOnPage

		if page.tabBadge then
			page.tabBadge.Visible = search ~= "" and visibleControlsOnPage > 0
			page.tabBadge.Text = tostring(visibleControlsOnPage)
		end

		if not firstMatchingPage and visibleControlsOnPage > 0 then
			firstMatchingPage = page
		end
	end

	if search ~= "" and self.currentTab and (self.currentTab._matchCount or 0) == 0 and firstMatchingPage then
		self:SelectPage({page = firstMatchingPage})
	end
end

function curl:Notify(options)
	options = options or {}
	pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title = options.title or "Notification",
			Text = tostring(options.text or ""),
			Duration = tonumber(options.duration) or 5
		})
	end)
end

function curl:Destroy()
	if self._destroyed then
		return
	end

	self._destroyed = true

	for _, connection in ipairs(self._connections or {}) do
		if connection and connection.Connected then
			connection:Disconnect()
		end
	end

	self._connections = {}
	self._controls = {}
	self._refreshCallbacks = {}
	self.pages = {}
	self.themeObjects = {}

	if self.gui then
		self.gui:Destroy()
	end
end

curl.Cleanup = curl.Destroy

