        local function hoverRow(row)
            local base = self.theme.ElementBG

            self:_connect(row.MouseEnter, function()
                tween(row, { BackgroundColor3 = Color3.fromRGB(
                    math.clamp(base.R * 255 + 10, 0, 255),
                    math.clamp(base.G * 255 + 10, 0, 255),
                    math.clamp(base.B * 255 + 10, 0, 255)
                ) }, 0.10)
            end)
            self:_connect(row.MouseLeave, function()
                tween(row, { BackgroundColor3 = self.theme.ElementBG }, 0.10)
            end)
