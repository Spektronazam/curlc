				bindText.Text = waitingForInput and "..." or bindToText(api.Value)
			end

			ui:_connect(bindButton.MouseButton1Click, function()
				waitingForInput = true
				refresh()
			end)

			ui:_connect(UserInputService.InputBegan, function(input, gpe)
				if gpe then
					return
				end

				if waitingForInput then
					local newBind = nil

					if input.UserInputType == Enum.UserInputType.Keyboard then
						if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Backspace then
							newBind = nil
						elseif input.KeyCode ~= Enum.KeyCode.Unknown then
							newBind = input.KeyCode
						end
					elseif input.UserInputType == Enum.UserInputType.MouseButton1
						or input.UserInputType == Enum.UserInputType.MouseButton2
						or input.UserInputType == Enum.UserInputType.MouseButton3 then
						newBind = input.UserInputType
					end

					waitingForInput = false
					api.Value = newBind
					refresh()
					safeCall(keyOptions.changedCallback, api.Value)
					return
				end

				if UserInputService:GetFocusedTextBox() then
					return
				end

				if api.Value and inputMatchesBind(input, api.Value) then
					safeCall(keyOptions.callback, api.Value)
				end
			end)

			function api:SetValue(bind, noCallback)
				api.Value = bind
				waitingForInput = false
				refresh()
				if not noCallback then
					safeCall(keyOptions.changedCallback, api.Value)
				end
			end

			refresh()
			ui:_registerControl(section, keyOptions.title or "Keybind", shell, "keybind", keyOptions.keywords)
			return api
		end

