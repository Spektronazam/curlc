-------------------------------------------------
-- Internal helpers
-------------------------------------------------
function curl:_connect(signal, fn)
    local c = signal:Connect(fn)
    self._connections[#self._connections + 1] = c
    return c
end

function curl:_bindTheme(obj, prop, key)
    self._themeBinds[#self._themeBinds + 1] = { obj = obj, prop = prop, key = key }
end

function curl:_applyTheme()
    for _, b in ipairs(self._themeBinds) do
        pcall(function() b.obj[b.prop] = self.theme[b.key] end)
    end
end

function curl:_setTabActive(page, active, instant)
    if not page or not page._tabBtn then return end

    local bg   = active and self.theme.ElementBG    or Color3.fromRGB(0,0,0)
    local bgT  = active and 0                       or 1
    local tc   = active and self.theme.TextColor     or self.theme.SubText
    local accT = active and 0                       or 1

    if instant then
        page._tabBtn.BackgroundColor3         = bg
        page._tabBtn.BackgroundTransparency   = bgT
        page._tabTitle.TextColor3             = tc
        page._tabAccent.BackgroundTransparency = accT
    else
        tween(page._tabBtn,    { BackgroundColor3 = bg, BackgroundTransparency = bgT }, 0.16)
        tween(page._tabTitle,  { TextColor3 = tc }, 0.16)
        tween(page._tabAccent, { BackgroundTransparency = accT }, 0.16)
    end
end

function curl:_setOpen(state, instant)
    if self._destroyed then return end
    self._isOpen = state

    if state then
        self.main.Visible            = true
        self._shadowHolder.Visible   = true
        if instant then
            self.main.Position = self._openPos
            self.mainScale.Scale = 1
            return
        end
        self.main.Position   = UDim2.new(self._openPos.X.Scale, self._openPos.X.Offset, self._openPos.Y.Scale, self._openPos.Y.Offset + 12)
        self.mainScale.Scale = 0.97
        tween(self.main,      { Position = self._openPos }, 0.22)
        tween(self.mainScale, { Scale = 1 }, 0.22)
    else
        if instant then
            self.main.Visible = false
            self._shadowHolder.Visible = false
            return
        end
        tween(self.main,      { Position = UDim2.new(self._openPos.X.Scale, self._openPos.X.Offset, self._openPos.Y.Scale, self._openPos.Y.Offset + 12) }, 0.16)
        tween(self.mainScale, { Scale = 0.97 }, 0.16)
        task.delay(0.17, function()
            if not self._isOpen then
                self.main.Visible          = false
                self._shadowHolder.Visible = false
                self.main.Position   = self._openPos
                self.mainScale.Scale = 1
            end
        end)
    end
end

function curl:_refreshSearch(rawQuery)
    self.searchQuery = trim(rawQuery or "")
    local q = lower(self.searchQuery)

    local firstHit = nil

    for _, page in ipairs(self.pages) do
        local pageSections = 0

        for _, sec in ipairs(page._sections or {}) do
            local secMatch = q ~= "" and string.find(lower(sec._title), q, 1, true)
            local ctrlVisible = 0

            for _, ctrl in ipairs(sec._controls or {}) do
                local haystack = lower(ctrl.title) .. " " .. lower(ctrl.kind)
                for _, kw in ipairs(ctrl.keywords or {}) do
                    haystack = haystack .. " " .. lower(kw)
                end
                haystack = haystack .. " " .. lower(sec._title) .. " " .. lower(page._title)

                local visible = q == "" or secMatch or string.find(haystack, q, 1, true)
                if ctrl.frame then
                    ctrl.frame.Visible = visible and true or false
                end
                if visible then ctrlVisible += 1 end
            end

            local showSec = q == "" or secMatch or ctrlVisible > 0
            if sec._frame then sec._frame.Visible = showSec end
            if showSec then pageSections += 1 end
        end

        page._matchCount = pageSections

        -- badge
        if page._tabBadge then
            page._tabBadge.Visible = q ~= "" and pageSections > 0
            page._tabBadge.Text    = tostring(pageSections)
        end

        if not firstHit and pageSections > 0 then firstHit = page end
    end

    -- auto-switch tab if current has 0 hits
    if q ~= "" and self.currentTab and (self.currentTab._matchCount or 0) == 0 and firstHit then
        self:selectPage(firstHit)
    end
end

-------------------------------------------------
-- Public API
-------------------------------------------------
function curl:toggle()
    self:_setOpen(not self._isOpen)
end

function curl:setTheme(key, color)
    self.theme[key] = color
    self:_applyTheme()
    for _, page in ipairs(self.pages) do
        self:_setTabActive(page, page == self.currentTab, true)
    end
end

function curl:selectPage(page)
    if not page or self.currentTab == page then return end

    local prev = self.currentTab
    self.currentTab = page

    if prev and prev._pageFrame then
        self:_setTabActive(prev, false)
        tween(prev._pageFrame, { Position = UDim2.new(0, -14, 0, 0) }, 0.14)
        task.delay(0.15, function()
            if prev._pageFrame and self.currentTab ~= prev then
                prev._pageFrame.Visible  = false
                prev._pageFrame.Position = UDim2.new(0, 0, 0, 0)
            end
        end)
    end

    page._pageFrame.Position = UDim2.new(0, 14, 0, 0)
    page._pageFrame.Visible  = true
    tween(page._pageFrame, { Position = UDim2.new(0, 0, 0, 0) }, 0.20)
    self:_setTabActive(page, true)
end

function curl:Destroy()
    if self._destroyed then return end
    self._destroyed = true
    for _, c in ipairs(self._connections) do
        if c and c.Connected then c:Disconnect() end
    end
    self._connections = {}
    self._controls    = {}
    self._themeBinds  = {}
    self.pages        = {}
    if self.gui then self.gui:Destroy() end
end
curl.Cleanup = curl.Destroy

