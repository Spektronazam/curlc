function curl:Track(task: any)
	return self._maid:GiveTask(task)
end

function curl:Bind(obj: Instance, prop: string, token: string)
	self._themeBindings[token] = self._themeBindings[token] or {}
	self._themeBindings[token][obj] = prop
	pcall(function()
		(obj :: any)[prop] = self.theme[token]
	end)
end

function curl:Tween(instance: Instance, properties: Dict, duration: number?, style: Enum.EasingStyle?, direction: Enum.EasingDirection?)
	local oldTween = self._tweens[instance]
	if oldTween then
		oldTween:Cancel()
	end

	local tw = TweenService:Create(
		instance,
		TweenInfo.new(duration or 0.18, style or Enum.EasingStyle.Quint, direction or Enum.EasingDirection.Out),
		properties
	)

	self._tweens[instance] = tw
	tw:Play()

	self:Track(tw.Completed:Connect(function()
		if self._tweens[instance] == tw then
			self._tweens[instance] = nil
		end
	end))

	return tw
end

function curl:_applyThemeToken(token: string, value: any)
	self.theme[token] = value
	local bucket = self._themeBindings[token]
	if bucket then
		for obj, prop in pairs(bucket) do
			pcall(function()
				(obj :: any)[prop] = value
			end)
		end
	end
end

function curl:setTheme(options: Dict)
	options = asTable(options)
	local token = asString(options.theme, "")
	local color = options.color3

	token = LEGACY_THEME_MAP[token] or token
	if self.theme[token] ~= nil and typeof(color) == "Color3" then
		self:_applyThemeToken(token, color)
	end
end

function curl:SetVisible(state: boolean)
	self.visible = state
	self.main.Visible = state
end

function curl:toggle()
	self:SetVisible(not self.visible)
end

function curl:_placeGui(gui: ScreenGui)
	if RunService:IsStudio() then
		gui.Parent = LocalPlayer:WaitForChild("PlayerGui")
		return
	end

	local ok = pcall(function()
		gui.Parent = CoreGui
	end)

	if not ok then
		gui.Parent = LocalPlayer:WaitForChild("PlayerGui")
	end
end

function curl:_openPopover(popover: Frame, anchor: GuiObject)
	local function sync()
		local pos = anchor.AbsolutePosition
		local size = anchor.AbsoluteSize
		popover.Position = UDim2.fromOffset(pos.X, pos.Y + size.Y + 6)
	end

	sync()
	popover.Visible = true
	popover.BackgroundTransparency = 1
	self:Tween(popover, {BackgroundTransparency = 0}, 0.14)

	local alive = true
	local conn
	conn = RunService.RenderStepped:Connect(function()
		if not alive or not popover.Visible or not anchor.Parent then
			if conn and conn.Connected then
				conn:Disconnect()
			end
			return
		end
		sync()
	end)

	self:Track(conn)

	return function()
		alive = false
		popover.Visible = false
	end
end

function curl:Notify(options: Dict)
	options = asTable(options)

	local title = asString(options.title, "Notification")
	local text = asString(options.text, "")
	local duration = asNumber(options.duration, 4, 0.2, 30)

	local card = createCard(self, self.toastHost, true)
	card.Size = UDim2.fromOffset(320, 0)
	card.AutomaticSize = Enum.AutomaticSize.Y

	local content = create("Frame", {
		BackgroundTransparency = 1,
		AutomaticSize = Enum.AutomaticSize.Y,
		Size = UDim2.new(1, 0, 0, 0),
	}, card)
	padding(content, 12, 12, 12, 12)
	local stack = listLayout(content, Enum.FillDirection.Vertical, 4)

	local titleLabel = createLabel(self, content, title, 13, true)
	titleLabel.Size = UDim2.new(1, 0, 0, 16)

	if text ~= "" then
		createDescription(self, content, text)
	end

	local scale = create("UIScale", {
		Scale = 0.96,
	}, card)

	card.BackgroundTransparency = 1
	self:Tween(card, {BackgroundTransparency = 0}, 0.16)
	self:Tween(scale, {Scale = 1}, 0.16)

	task.delay(duration, function()
		if not card.Parent then
			return
		end
		self:Tween(card, {BackgroundTransparency = 1}, 0.14)
		self:Tween(scale, {Scale = 0.96}, 0.14)
		task.delay(0.16, function()
			if card then
				card:Destroy()
			end
		end)
	end)

	return card, stack
end

function curl:RegisterCommand(options: Dict)
	options = asTable(options)

	local entry = {
		title = asString(options.title, "Command"),
		description = asString(options.description, ""),
		keywords = asTable(options.keywords),
		callback = asCallback(options.callback),
	}

	table.insert(self._commands, entry)
	self:_renderCommandPalette()
	return entry
end

function curl:_renderCommandPalette()
	if not self.commandList then
		return
	end

	for _, child in ipairs(self.commandList:GetChildren()) do
		if child:IsA("GuiObject") then
			child:Destroy()
		end
	end

	local query = string.lower(self.commandSearch.Text)
	for _, command in ipairs(self._commands) do
		local haystack = string.lower(command.title .. " " .. command.description)
		for _, word in ipairs(command.keywords) do
			haystack ..= " " .. string.lower(tostring(word))
		end

		if query == "" or string.find(haystack, query, 1, true) then
			local row = create("TextButton", {
				AutoButtonColor = false,
				BackgroundColor3 = self.theme.accent,
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 42),
				Text = "",
				ZIndex = 52,
			}, self.commandList)

			corner(row, self.theme.radiusMd)
			self:Bind(row, "BackgroundColor3", "accent")

			local titleLabel = create("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, -12, 0, 18),
				Position = UDim2.fromOffset(12, 7),
				Text = command.title,
				Font = Enum.Font.GothamMedium,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 53,
			}, row) :: TextLabel
			self:Bind(titleLabel, "TextColor3", "foreground")

			local descLabel = create("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, -12, 0, 14),
				Position = UDim2.fromOffset(12, 21),
				Text = command.description,
				Font = Enum.Font.Gotham,
				TextSize = 10,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 53,
			}, row) :: TextLabel
			self:Bind(descLabel, "TextColor3", "mutedForeground")

			scalePressable(self, row)

			self:Track(row.MouseEnter:Connect(function()
				self:Tween(row, {BackgroundTransparency = 0.2}, 0.12)
			end))
			self:Track(row.MouseLeave:Connect(function()
				self:Tween(row, {BackgroundTransparency = 1}, 0.12)
			end))
			self:Track(row.MouseButton1Click:Connect(function()
				self:CloseCommandPalette()
				safeCall(command.callback)
			end))
		end
	end
end

function curl:_buildCommandPalette()
	local backdrop = create("TextButton", {
		AutoButtonColor = false,
		BackgroundColor3 = Color3.new(0, 0, 0),
		BackgroundTransparency = 0.35,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Visible = false,
		Text = "",
		ZIndex = 50,
	}, self.overlayLayer) :: TextButton

	local shell = create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0),
		BackgroundColor3 = self.theme.popover,
		BorderSizePixel = 0,
		Position = UDim2.new(0.5, 0, 0, 90),
		Size = UDim2.fromOffset(560, 420),
		ZIndex = 51,
	}, backdrop) :: Frame

	corner(shell, self.theme.radiusLg)
	local shellStroke = stroke(shell, self.theme.border, 0.88)
	self:Bind(shell, "BackgroundColor3", "popover")
	self:Bind(shellStroke, "Color", "border")

	local header = create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 54),
		ZIndex = 52,
	}, shell)
	padding(header, 12, 12, 12, 8)

	local inputShell, inputStroke = createInputShell(self, header, 536)
	inputShell.ZIndex = 52
	inputStroke.ZIndex = 53

	local search = create("TextBox", {
		BackgroundTransparency = 1,
		ClearTextOnFocus = false,
		PlaceholderText = "Type a command or page name...",
		Size = UDim2.new(1, -16, 1, 0),
		Position = UDim2.fromOffset(8, 0),
		Text = "",
		Font = Enum.Font.Gotham,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 54,
	}, inputShell) :: TextBox
	self:Bind(search, "TextColor3", "foreground")
	search.PlaceholderColor3 = self.theme.mutedForeground

	local results = create("ScrollingFrame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		CanvasSize = UDim2.fromOffset(0, 0),
		ScrollBarThickness = 4,
		Position = UDim2.fromOffset(12, 58),
		Size = UDim2.new(1, -24, 1, -70),
		ZIndex = 52,
	}, shell) :: ScrollingFrame

	local list = create("Frame", {
		BackgroundTransparency = 1,
		AutomaticSize = Enum.AutomaticSize.Y,
		Size = UDim2.new(1, -4, 0, 0),
	}, results)
	local layout = listLayout(list, Enum.FillDirection.Vertical, 6)

	self:Track(layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		results.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 6)
	end))

	self:Track(backdrop.MouseButton1Click:Connect(function()
		self:CloseCommandPalette()
	end))

	self:Track(search:GetPropertyChangedSignal("Text"):Connect(function()
		self:_renderCommandPalette()
	end))

	self.commandBackdrop = backdrop
	self.commandShell = shell
	self.commandSearch = search
	self.commandList = list
end

function curl:OpenCommandPalette()
	self.commandBackdrop.Visible = true
	self.commandSearch.Text = ""
	self:_renderCommandPalette()
	task.defer(function()
		self.commandSearch:CaptureFocus()
	end)
end

function curl:CloseCommandPalette()
	self.commandBackdrop.Visible = false
	self.commandSearch.Text = ""
end

function curl:ToggleCommandPalette()
	if self.commandBackdrop.Visible then
		self:CloseCommandPalette()
	else
		self:OpenCommandPalette()
	end
end

function curl:OpenDialog(options: Dict)
	options = asTable(options)

	local title = asString(options.title, "Dialog")
	local description = asString(options.description, "")
	local actions = asTable(options.actions)

	local backdrop = create("TextButton", {
		AutoButtonColor = false,
		BackgroundColor3 = Color3.new(0, 0, 0),
