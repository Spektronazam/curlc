local Maid = {}
Maid.__index = Maid

function Maid.new()
	return setmetatable({
		_tasks = {},
	}, Maid)
end

function Maid:GiveTask(task: any)
	table.insert(self._tasks, task)
	return task
end

function Maid:DoCleaning()
	for i = #self._tasks, 1, -1 do
		local task = self._tasks[i]
		local kind = typeof(task)

		if kind == "RBXScriptConnection" then
			if task.Connected then
				task:Disconnect()
			end
		elseif kind == "Instance" then
			task:Destroy()
		elseif type(task) == "function" then
			task()
		elseif type(task) == "table" and type(task.Destroy) == "function" then
			task:Destroy()
		end

		self._tasks[i] = nil
	end
end

local function create(className: string, props: Dict?, parent: Instance?): Instance
	local obj = Instance.new(className)
	if props then
		for k, v in pairs(props) do
			(obj :: any)[k] = v
		end
	end
	if parent then
		obj.Parent = parent
	end
	return obj
end

local function deepCopy(tbl: Dict): Dict
	local newTbl = {}
	for k, v in pairs(tbl) do
		if type(v) == "table" then
			newTbl[k] = deepCopy(v)
		else
			newTbl[k] = v
		end
	end
	return newTbl
end

local function asTable(value: any): Dict
	return type(value) == "table" and value or {}
end

local function asString(value: any, fallback: string): string
	return type(value) == "string" and value or fallback
end

local function asBoolean(value: any, fallback: boolean): boolean
	return type(value) == "boolean" and value or fallback
end

local function asNumber(value: any, fallback: number, minValue: number?, maxValue: number?): number
	local n = type(value) == "number" and value or fallback
	if minValue ~= nil then
		n = math.max(minValue, n)
	end
	if maxValue ~= nil then
		n = math.min(maxValue, n)
	end
	return n
end

local function asColor3(value: any, fallback: Color3): Color3
	return typeof(value) == "Color3" and value or fallback
end

local function asCallback(value: any): (...any) -> ()
	if type(value) == "function" then
		return value
	end
	return function() end
end

local function asKeyCode(value: any, fallback: Enum.KeyCode): Enum.KeyCode
	return typeof(value) == "EnumItem" and value.EnumType == Enum.KeyCode and value or fallback
end

local function clamp01(x: number): number
	return math.clamp(x, 0, 1)
end

local function roundStep(value: number, step: number): number
	return math.floor((value / step) + 0.5) * step
end

local function colorToHex(color: Color3): string
	return string.format(
		"#%02X%02X%02X",
		math.round(color.R * 255),
		math.round(color.G * 255),
		math.round(color.B * 255)
	)
end

local function safeCall(callback: (...any) -> (), ...)
	local args = table.pack(...)
	task.spawn(function()
		pcall(function()
			callback(table.unpack(args, 1, args.n))
		end)
	end)
end

local function corner(obj: Instance, radius: number)
	local c = create("UICorner", {
		CornerRadius = UDim.new(0, radius),
	}, obj)
	return c
end

local function stroke(obj: Instance, color: Color3, transparency: number?)
	local s = create("UIStroke", {
		Color = color,
		Transparency = transparency or 0,
		Thickness = 1,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
	}, obj)
	return s
end

local function padding(obj: Instance, left: number, right: number, top: number, bottom: number)
	return create("UIPadding", {
		PaddingLeft = UDim.new(0, left),
		PaddingRight = UDim.new(0, right),
		PaddingTop = UDim.new(0, top),
		PaddingBottom = UDim.new(0, bottom),
	}, obj)
end

local function listLayout(obj: Instance, fillDirection: Enum.FillDirection?, padPx: number?)
	return create("UIListLayout", {
		FillDirection = fillDirection or Enum.FillDirection.Vertical,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, padPx or 8),
	}, obj)
end

local function scalePressable(ui, button: GuiButton)
	local scale = create("UIScale", {
		Scale = 1,
	}, button)

	ui:Track(button.MouseEnter:Connect(function()
		ui:Tween(scale, {Scale = 1.01}, 0.12)
	end))

	ui:Track(button.MouseLeave:Connect(function()
		ui:Tween(scale, {Scale = 1}, 0.12)
	end))

	ui:Track(button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			ui:Tween(scale, {Scale = 0.985}, 0.06)
		end
	end))

	ui:Track(button.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			ui:Tween(scale, {Scale = 1.01}, 0.08)
		end
	end))
end

local function bindText(ui, label: TextLabel, token: string)
	ui:Bind(label, "TextColor3", token)
end

local function createLabel(ui, parent: Instance, text: string, size: number?, bold: boolean?): TextLabel
	local label = create("TextLabel", {
		BackgroundTransparency = 1,
		AutomaticSize = Enum.AutomaticSize.Y,
		Size = UDim2.new(1, 0, 0, 0),
		Text = text,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		Font = bold and Enum.Font.GothamBold or Enum.Font.GothamMedium,
		TextSize = size or 13,
	}, parent) :: TextLabel
	bindText(ui, label, "cardForeground")
	return label
end

local function createDescription(ui, parent: Instance, text: string): TextLabel
	local label = create("TextLabel", {
		BackgroundTransparency = 1,
		AutomaticSize = Enum.AutomaticSize.Y,
		Size = UDim2.new(1, 0, 0, 0),
		Text = text,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		Font = Enum.Font.Gotham,
		TextSize = 11,
	}, parent) :: TextLabel
	bindText(ui, label, "mutedForeground")
	return label
end

local function createCard(ui, parent: Instance, autoY: boolean?): Frame
	local card = create("Frame", {
		BackgroundColor3 = ui.theme.card,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = autoY == false and Enum.AutomaticSize.None or Enum.AutomaticSize.Y,
	}, parent) :: Frame

	corner(card, ui.theme.radiusLg)
	local outline = stroke(card, ui.theme.border, 0.9)
	ui:Bind(card, "BackgroundColor3", "card")
	ui:Bind(outline, "Color", "border")
	return card
end

local function createSeparator(ui, parent: Instance): Frame
	local sep = create("Frame", {
		BackgroundColor3 = ui.theme.border,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 1),
	}, parent) :: Frame
	ui:Bind(sep, "BackgroundColor3", "border")
	sep.BackgroundTransparency = 0.9
	return sep
end

local function createScrollArea(ui, parent: Instance, size: UDim2, position: UDim2?): (ScrollingFrame, UIListLayout)
	local scroll = create("ScrollingFrame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = size,
		Position = position or UDim2.fromScale(0, 0),
		CanvasSize = UDim2.fromOffset(0, 0),
		ScrollBarThickness = 4,
		AutomaticCanvasSize = Enum.AutomaticSize.None,
	}, parent) :: ScrollingFrame

	local content = create("Frame", {
		BackgroundTransparency = 1,
		AutomaticSize = Enum.AutomaticSize.Y,
		Size = UDim2.new(1, -6, 0, 0),
	}, scroll)

	padding(content, 0, 4, 0, 6)
	local layout = listLayout(content, Enum.FillDirection.Vertical, 10)

	ui:Track(layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		scroll.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 6)
	end))

	return scroll, layout
end

local function createInputShell(ui, parent: Instance, width: number): (Frame, UIStroke)
	local shell = create("Frame", {
		BackgroundColor3 = ui.theme.input,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(width, 36),
	}, parent) :: Frame
	corner(shell, ui.theme.radiusMd)
	local outline = stroke(shell, ui.theme.border, 0.88)
	ui:Bind(shell, "BackgroundColor3", "input")
	ui:Bind(outline, "Color", "border")
	return shell, outline
end

local function createButtonShell(ui, parent: Instance, width: number, text: string, variant: ButtonVariant?): TextButton
	local style = BUTTON_STYLES[variant or "secondary"]
	local button = create("TextButton", {
		AutoButtonColor = false,
		BackgroundColor3 = ui.theme[style.bg],
		BackgroundTransparency = style.idle,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(width, 36),
		Text = text,
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
	}, parent) :: TextButton

	corner(button, ui.theme.radiusMd)
	ui:Bind(button, "BackgroundColor3", style.bg)
	ui:Bind(button, "TextColor3", style.fg)

	if style.border then
		local outline = stroke(button, ui.theme[style.border], 0.88)
		ui:Bind(outline, "Color", style.border)
	end

	scalePressable(ui, button)

	ui:Track(button.MouseEnter:Connect(function()
		ui:Tween(button, {BackgroundTransparency = style.hover}, 0.12)
	end))

	ui:Track(button.MouseLeave:Connect(function()
		ui:Tween(button, {BackgroundTransparency = style.idle}, 0.12)
	end))

	return button
end

local function createPopoverShell(ui, size: UDim2): Frame
	local popover = create("Frame", {
		BackgroundColor3 = ui.theme.popover,
		BorderSizePixel = 0,
		Size = size,
		Visible = false,
		ZIndex = 40,
	}, ui.overlayLayer) :: Frame

	corner(popover, ui.theme.radiusLg)
	local outline = stroke(popover, ui.theme.border, 0.88)
	ui:Bind(popover, "BackgroundColor3", "popover")
	ui:Bind(outline, "Color", "border")
	padding(popover, 10, 10, 10, 10)
	return popover
end

