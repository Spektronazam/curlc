                    keyBtn.Text = currentKey.Name
                    keyBtn.TextColor3 = self.theme.TextColor
                    safeCall(opts.onChanged or function() end, currentKey)
                end
            end)

            self:_connect(UserInputService.InputBegan, function(inp, gpe)
                if gpe then return end
                if not listening and inp.KeyCode == currentKey then
                    safeCall(opts.callback or function() end)
                end
            end)

            hoverRow(row)

            local kbObj = {
                value = currentKey,
                set   = function(key)
                    currentKey = key
                    keyBtn.Text = key.Name
                end,
            }

            regCtrl(opts.title, row, "keybind", opts.keywords)
            return kbObj, secAPI
