function Section:addToggle(options: Dict)
	options = asTable(options)

	local title = asString(options.title, "Toggle")
	local description = asString(options.description, "")
	local callback = asCallback(options.callback)
	local state = asBoolean(options.default, false)

	local _, _, right = self:_row(title, description)
	local toggleBtn = create("TextButton", {
		AutoButtonColor = false,
		BackgroundColor3 = self.window.theme.input,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(42, 24),
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, 0, 0.5, 0),
		Text = "",
	}, right) :: TextButton

	corner(toggleBtn, 999)
	local toggleStroke = stroke(toggleBtn, self.window.theme.border, 0.88)
	self.window:Bind(toggleBtn, "BackgroundColor3", "input")
	self.window:Bind(toggleStroke, "Color", "border")

	local knob = create("Frame", {
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(18, 18),
		AnchorPoint = Vector2.new(0, 0.5),
		Position = UDim2.new(0, 3, 0.5, 0),
	}, toggleBtn) :: Frame
	corner(knob, 999)

	local function render(fire: boolean?)
		if state then
			self.window:_applyThemeToken("input", self.window.theme.input)
			self.window:Tween(toggleBtn, {BackgroundColor3 = self.window.theme.primary}, 0.14)
			self.window:Tween(knob, {Position = UDim2.new(0, 21, 0.5, 0)}, 0.14)
		else
			self.window:Tween(toggleBtn, {BackgroundColor3 = self.window.theme.input}, 0.14)
			self.window:Tween(knob, {Position = UDim2.new(0, 3, 0.5, 0)}, 0.14)
		end
		if fire then
			safeCall(callback, state)
		end
	end

	self.window:Track(toggleBtn.MouseButton1Click:Connect(function()
		state = not state
		render(true)
	end))

	render(false)

	local handle = {}
	function handle:Set(nextState: boolean)
		state = nextState
		render(true)
	end
	function handle:Get()
		return state
	end
	function handle:Destroy()
		right.Parent.Parent:Destroy()
	end
	return handle
end

function Section:addSlider(options: Dict)
	options = asTable(options)

	local title = asString(options.title, "Slider")
	local description = asString(options.description, "")
	local callback = asCallback(options.callback)

	local min = asNumber(options.min, 0)
	local max = asNumber(options.max, 100)
	if max < min then
		min, max = max, min
	end

	local step = asNumber(options.step, 1, 0.001)
	local range = math.max(max - min, step)
	local value = asNumber(options.default, min, min, max)

	local row = createCard(self.window, self.container, false)
	row.Size = UDim2.new(1, 0, 0, description ~= "" and 82 or 66)

	local titleLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(12, 10),
		Size = UDim2.new(1, -92, 0, 16),
		Text = title,
		TextXAlignment = Enum.TextXAlignment.Left,
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
	}, row) :: TextLabel
	self.window:Bind(titleLabel, "TextColor3", "cardForeground")

	local valueLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.new(1, -12, 10 / row.AbsoluteSize.Y, 0),
		Size = UDim2.fromOffset(80, 16),
		Text = tostring(value),
		TextXAlignment = Enum.TextXAlignment.Right,
		Font = Enum.Font.Gotham,
		TextSize = 11,
	}, row) :: TextLabel
	self.window:Bind(valueLabel, "TextColor3", "mutedForeground")

	if description ~= "" then
		local descLabel = create("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.fromOffset(12, 28),
			Size = UDim2.new(1, -24, 0, 12),
			Text = description,
			TextXAlignment = Enum.TextXAlignment.Left,
			Font = Enum.Font.Gotham,
			TextSize = 10,
		}, row) :: TextLabel
		self.window:Bind(descLabel, "TextColor3", "mutedForeground")
	end

	local barY = description ~= "" and 56 or 38
	local bar = create("TextButton", {
		AutoButtonColor = false,
		BackgroundColor3 = self.window.theme.input,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(12, barY),
		Size = UDim2.new(1, -24, 0, 10),
		Text = "",
	}, row) :: TextButton
	corner(bar, 999)
	self.window:Bind(bar, "BackgroundColor3", "input")

	local fill = create("Frame", {
		BackgroundColor3 = self.window.theme.primary,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, 0),
	}, bar) :: Frame
	corner(fill, 999)

	local dragging = false

	local function setValue(nextValue: number, fire: boolean?)
		value = roundStep(math.clamp(nextValue, min, max), step)
		local pct = (value - min) / range
		fill.Size = UDim2.new(pct, 0, 1, 0)
		valueLabel.Text = tostring(value)
		if fire then
			safeCall(callback, value)
		end
	end

	local function updateFromInput(input: InputObject)
		local pct = clamp01((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
		setValue(min + range * pct, true)
	end

	self.window:Track(bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateFromInput(input)
		end
	end))

	self.window:Track(UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateFromInput(input)
		end
	end))

	self.window:Track(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end))

	setValue(value, false)

	local handle = {}
	function handle:Set(nextValue: number)
		setValue(nextValue, true)
	end
	function handle:Get()
		return value
	end
	function handle:Destroy()
		row:Destroy()
	end
	return handle
end

function Section:addTextbox(options: Dict)
	options = asTable(options)

	local title = asString(options.title, "Textbox")
	local description = asString(options.description, "")
	local callback = asCallback(options.callback)
	local placeholder = asString(options.placeholder, "Type...")
	local defaultValue = tostring(options.default or "")

	local _, _, right = self:_row(title, description)

	local shell, outline = createInputShell(self.window, right, 170)
	local box = create("TextBox", {
		BackgroundTransparency = 1,
		ClearTextOnFocus = false,
		PlaceholderText = placeholder,
		Size = UDim2.new(1, -16, 1, 0),
		Position = UDim2.fromOffset(8, 0),
		Text = defaultValue,
		Font = Enum.Font.Gotham,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, shell) :: TextBox
	self.window:Bind(box, "TextColor3", "foreground")
	box.PlaceholderColor3 = self.window.theme.mutedForeground

	self.window:Track(box.Focused:Connect(function()
		self.window:Tween(outline, {Color = self.window.theme.ring, Transparency = 0.35}, 0.12)
	end))
	self.window:Track(box.FocusLost:Connect(function()
		self.window:Tween(outline, {Color = self.window.theme.border, Transparency = 0.88}, 0.12)
		safeCall(callback, box.Text)
	end))

	local handle = {}
	function handle:Set(text: string)
		box.Text = text
	end
	function handle:Get()
		return box.Text
	end
	function handle:Destroy()
		right.Parent.Parent:Destroy()
	end
	return handle
end

function Section:addDropdown(options: Dict)
	options = asTable(options)

	local title = asString(options.title, "Dropdown")
	local description = asString(options.description, "")
	local callback = asCallback(options.callback)
	local items = asTable(options.items)
	local selected = options.default

	local _, _, right = self:_row(title, description)

	local trigger = createButtonShell(self.window, right, 170, tostring(selected or "Select"), "outline")
	local popover = createPopoverShell(self.window, UDim2.fromOffset(220, math.max(48, (#items * 32) + 20)))
	local closePopover = function() popover.Visible = false end

	local list = create("Frame", {
		BackgroundTransparency = 1,
		AutomaticSize = Enum.AutomaticSize.Y,
		Size = UDim2.new(1, 0, 0, 0),
	}, popover)
	listLayout(list, Enum.FillDirection.Vertical, 6)

	local function setValue(value: any, fire: boolean?)
		selected = value
		trigger.Text = tostring(value)
		if fire then
			safeCall(callback, value)
		end
	end

	for _, item in ipairs(items) do
		local value = item
		if type(item) == "table" then
			value = item.value
		end
		local text = type(item) == "table" and tostring(item.label or item.value) or tostring(item)

		local btn = createButtonShell(self.window, list, 200, text, "ghost")
		self.window:Track(btn.MouseButton1Click:Connect(function()
			setValue(value, true)
			closePopover()
		end))
	end

	self.window:Track(trigger.MouseButton1Click:Connect(function()
		if popover.Visible then
			closePopover()
		else
			self:_openPopover(popover, trigger)
		end
	end))

	if selected ~= nil then
		setValue(selected, false)
	end

	local handle = {}
	function handle:Set(value: any)
		setValue(value, true)
	end
	function handle:Get()
		return selected
	end
	function handle:Destroy()
		popover:Destroy()
		right.Parent.Parent:Destroy()
	end
	return handle
end

