            btn.BackgroundTransparency = 1
            btn.Text = ""
            btn.Parent = frame
            
            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(0.5, -10, 1, 0)
            lbl.Position = UDim2.new(0, 10, 0, 0)
            lbl.BackgroundTransparency = 1
            lbl.Text = cpOptions.title or "Color Picker"
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 13
            lbl.Parent = frame
            ui:registerTheme(lbl, "TextColor3", "TextColor")
            
            local display = Instance.new("Frame")
            display.Size = UDim2.new(0, 36, 0, 18)
            display.Position = UDim2.new(1, -44, 0.5, -9)
            display.BackgroundColor3 = color
            display.Parent = frame
            Instance.new("UICorner", display).CornerRadius = UDim.new(0, 4)
            
            local pickerFrame = Instance.new("Frame")
            pickerFrame.Size = UDim2.new(1, -20, 0, 90)
            pickerFrame.Position = UDim2.new(0, 10, 0, 36)
            pickerFrame.BackgroundTransparency = 1
            pickerFrame.Parent = frame
            
            local function createSlider(yPos, compColor, compStr)
                local sBg = Instance.new("TextButton")
                sBg.Size = UDim2.new(1, 0, 0, 14)
                sBg.Position = UDim2.new(0, 0, 0, yPos)
                sBg.BackgroundColor3 = ui.theme.Background
                sBg.Text = ""
                sBg.AutoButtonColor = false
                sBg.Parent = pickerFrame
                Instance.new("UICorner", sBg).CornerRadius = UDim.new(1, 0)
                ui:registerTheme(sBg, "BackgroundColor3", "Background")
                
                local sFill = Instance.new("Frame")
                sFill.Size = UDim2.new(compStr == "R" and color.R or (compStr == "G" and color.G or color.B), 0, 1, 0)
                sFill.BackgroundColor3 = compColor
                sFill.Parent = sBg
                Instance.new("UICorner", sFill).CornerRadius = UDim.new(1, 0)
                
                local drag = false
                local function update(input)
                    local pct = math.clamp((input.Position.X - sBg.AbsolutePosition.X) / sBg.AbsoluteSize.X, 0, 1)
                    sFill.Size = UDim2.new(pct, 0, 1, 0)
                    local r = compStr == "R" and pct or color.R
                    local g = compStr == "G" and pct or color.G
                    local b = compStr == "B" and pct or color.B
                    color = Color3.new(r, g, b)
                    display.BackgroundColor3 = color
                    safeCall(callback, color)
                end
                
                sBg.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        drag = true
                        update(input)
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then drag = false end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if drag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then update(input) end
                end)
            end
            
            createSlider(0, Color3.fromRGB(255, 75, 75), "R")
            createSlider(24, Color3.fromRGB(75, 255, 75), "G")
            createSlider(48, Color3.fromRGB(75, 125, 255), "B")
            
            btn.MouseButton1Click:Connect(function()
                open = not open
                tween(frame, {Size = UDim2.new(1, 0, 0, open and 110 or 32)}, 0.2)
            end)
        end

        return section
    end
    return page
end

pcall(function()
    game.StarterGui:SetCore("SendNotification", {
        Title = "curl -c",
        Text = "done loading ok bye",
        Duration = 3
    })
end)

return curl
