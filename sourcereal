            btn.Font = Enum.Font.Gotham
            btn.TextSize = 13
            btn.Parent = frame
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
            ui:registerTheme(btn, "BackgroundColor3", "Background")
            ui:registerTheme(btn, "TextColor3", "Accent")
            
