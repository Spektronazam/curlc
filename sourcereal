end)

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local curl = {}
curl.__index = curl

local defaultThemes = {
    Background = Color3.fromRGB(24, 24, 24),
    Glow = Color3.fromRGB(0, 0, 0),
    Accent = Color3.fromRGB(10, 10, 10),
    LightContrast = Color3.fromRGB(20, 20, 20),
    DarkContrast = Color3.fromRGB(14, 14, 14),
    TextColor = Color3.fromRGB(255, 255, 255)
}

-- Utility: Smooth Tweening
local function tween(instance, properties, duration)
    duration = duration or 0.2
    local tw = TweenService:Create(instance, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), properties)
    tw:Play()
    return tw
end

-- Utility: Safe Callback execution
local function safeCall(func, ...)
    if type(func) ~= "function" then return end
    local args = {...}
    task.spawn(function()
        pcall(function()
            func(unpack(args))
        end)
    end)
end

function curl.new(options)
    options = options or {}
    local self = setmetatable({}, curl)

    local title = "curl -c" 

    self.pages = {}
    self.theme = {}
    for k, v in pairs(defaultThemes) do self.theme[k] = v end
    self.themeObjects = {}

    -- Base GUI
    local gui = Instance.new("ScreenGui")
    gui.Name = "curl-c"
    gui.ResetOnSpawn = false
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    
    if RunService:IsStudio() then
        gui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
    else
        local success = pcall(function() gui.Parent = CoreGui end)
        if not success then gui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui") end
    end

    -- Main Container
    local main = Instance.new("Frame")
    main.Name = "Main"
    main.Size = UDim2.new(0, 550, 0, 400)
    main.Position = UDim2.new(0.5, -275, 0.5, -200)
    main.BackgroundColor3 = self.theme.Background
    main.BorderSizePixel = 0
    main.ClipsDescendants = true
    main.Parent = gui
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 8)
    
    local shadow = Instance.new("UIStroke")
    shadow.Color = self.theme.Glow
    shadow.Thickness = 2
    shadow.Transparency = 0.5
    shadow.Parent = main

    -- Smooth Dragging
    local dragging, dragInput, dragStart, startPos
    main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    main.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- Topbar
    local topbar = Instance.new("Frame")
    topbar.Size = UDim2.new(1, 0, 0, 40)
    topbar.BackgroundColor3 = self.theme.DarkContrast
    topbar.BorderSizePixel = 0
    topbar.Parent = main
    
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -20, 1, 0)
    titleLabel.Position = UDim2.new(0, 15, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 16
    titleLabel.TextColor3 = self.theme.TextColor
    titleLabel.Parent = topbar

    -- Sidebar (Tabs)
    local tabContainer = Instance.new("Frame")
    tabContainer.Size = UDim2.new(0, 140, 1, -40)
    tabContainer.Position = UDim2.new(0, 0, 0, 40)
    tabContainer.BackgroundColor3 = self.theme.LightContrast
    tabContainer.BorderSizePixel = 0
    tabContainer.Parent = main

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Padding = UDim.new(0, 2)
    tabLayout.Parent = tabContainer

    Instance.new("UIPadding", tabContainer).PaddingTop = UDim.new(0, 10)

    -- Page Container
    local pageContainer = Instance.new("Frame")
    pageContainer.Size = UDim2.new(1, -140, 1, -40)
    pageContainer.Position = UDim2.new(0, 140, 0, 40)
    pageContainer.BackgroundTransparency = 1
    pageContainer.Parent = main

    -- Toggle Hotkey
    UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Enum.KeyCode.RightShift then
            self:toggle()
        end
    end)

    self.gui = gui
    self.main = main
    self.tabContainer = tabContainer
    self.pageContainer = pageContainer
    self.currentTab = nil

    self:registerTheme(main, "BackgroundColor3", "Background")
    self:registerTheme(shadow, "Color", "Glow")
    self:registerTheme(topbar, "BackgroundColor3", "DarkContrast")
    self:registerTheme(tabContainer, "BackgroundColor3", "LightContrast")
    self:registerTheme(titleLabel, "TextColor3", "TextColor")

    return self
end

function curl:registerTheme(obj, prop, themeName)
    if not self.themeObjects[themeName] then self.themeObjects[themeName] = {} end
    self.themeObjects[themeName][obj] = prop
    pcall(function() obj[prop] = self.theme[themeName] end)
end

function curl:updateTheme(themeName, color)
    self.theme[themeName] = color
    if self.themeObjects[themeName] then
        for obj, prop in pairs(self.themeObjects[themeName]) do
            pcall(function() obj[prop] = color end)
        end
    end
end

function curl:setTheme(options)
    if options.theme and options.color3 then
        self:updateTheme(options.theme, options.color3)
    end
end

function curl:toggle()
    self.main.Visible = not self.main.Visible
end

function curl:Notify(options)
    options = options or {}
    pcall(function()
        game.StarterGui:SetCore("SendNotification", {
            Title = options.title or "Notification",
            Text = tostring(options.text or ""),
            Duration = 5
        })
    end)
end

function curl:SelectPage(options)
    local page = options.page
    if not page then return end
    
    if self.currentTab then
        self.currentTab.pageFrame.Visible = false
        tween(self.currentTab.tabButton, {BackgroundColor3 = self.theme.LightContrast, TextColor3 = self.theme.TextColor}, 0.2)
    end
    
    self.currentTab = page
    page.pageFrame.Visible = true
    tween(page.tabButton, {BackgroundColor3 = self.theme.DarkContrast, TextColor3 = self.theme.Accent}, 0.2)

    if options.toggle ~= nil then self.main.Visible = options.toggle end
end

