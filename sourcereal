            end)
            
            UserInputService.InputBegan:Connect(function(input, gpe)
                if listening then
                    local valid = false
                    if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
                        key = input.KeyCode
                        valid = true
                    elseif input.UserInputType.Name:find("MouseButton") then
                        key = input.UserInputType
                        valid = true
                    end
                    
                    if valid then
                        listening = false
                        btn.Text = key.Name
                        tween(btn, {BackgroundColor3 = ui.theme.Background}, 0.2)
                        ui:registerTheme(btn, "TextColor3", "Accent")
                        safeCall(changedCallback, key)
                    end
                elseif not gpe then
                    if input.KeyCode == key and key ~= Enum.KeyCode.Unknown then
                        safeCall(callback)
                    elseif input.UserInputType == key and key ~= Enum.UserInputType.Unknown then
                        safeCall(callback)
                    end
                end
            end)
        end

        function section:addSlider(slOptions)
            local min, max = slOptions.min or 0, slOptions.max or 100
            local val = slOptions.default or min
            local callback = slOptions.callback or function() end
            
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 45)
            frame.BackgroundColor3 = ui.theme.DarkContrast
            frame.Parent = secFrame
            Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 4)
            ui:registerTheme(frame, "BackgroundColor3", "DarkContrast")
            
            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(1, -20, 0, 20)
            lbl.Position = UDim2.new(0, 10, 0, 4)
            lbl.BackgroundTransparency = 1
            lbl.Text = (slOptions.title or "Slider") .. ": " .. tostring(val)
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 13
            lbl.Parent = frame
            ui:registerTheme(lbl, "TextColor3", "TextColor")
            
            local sliderBg = Instance.new("TextButton")
            sliderBg.Size = UDim2.new(1, -20, 0, 8)
            sliderBg.Position = UDim2.new(0, 10, 0, 28)
            sliderBg.BackgroundColor3 = ui.theme.Background
            sliderBg.Text = ""
            sliderBg.AutoButtonColor = false
            sliderBg.Parent = frame
            Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(1, 0)
            ui:registerTheme(sliderBg, "BackgroundColor3", "Background")
            
            local fill = Instance.new("Frame")
            fill.Size = UDim2.new(math.clamp((val - min) / (max - min), 0, 1), 0, 1, 0)
            fill.BackgroundColor3 = ui.theme.Accent
            fill.Parent = sliderBg
            Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
            ui:registerTheme(fill, "BackgroundColor3", "Accent")
            
            local drag = false
            local function update(input)
                local pct = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
                val = math.floor(min + (max - min) * pct)
                tween(fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.1)
                lbl.Text = (slOptions.title or "Slider") .. ": " .. tostring(val)
                safeCall(callback, val)
            end
            
            sliderBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    drag = true
                    update(input)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    drag = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if drag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    update(input)
                end
            end)
        end

